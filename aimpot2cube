def read_commmand_line() -> tuple[IO[str], Optional[IO[str]]]:
    """Gets input filename(s).

    If no input file is provided in command line the default input file is used.

    Sets global verbose output flag if specified in cmd line args.

    Args:
        None

    Returns:
        grid_vec_infile: Filename of grid vectors input file
        aimpro_infile: Filename of AIMPRO potential job output

    Raises:
        Errors & exits with message if incorrect number of args detected.
        Errors & exits with message if provided input file does not exist.
        Warns if AIMPRO output file does not match conventional AIM.sh.o* format.
    """
    global verbose_output, debug, use_hartree

    parser = argparse.ArgumentParser(
                    prog = "aimpot2cube",
                    formatter_class=argparse.RawDescriptionHelpFormatter,
                    description = "A parser to convert the output of an AIMPRO potential job to the cubefile format (in eV). \
                        \n\nAIMPRO potential job documentation: https://www.staff.ncl.ac.uk/j.p.goss/AIMPRO/restricted/docs/analysis/potential.html\
                        \ncubefile format: https://paulbourke.net/dataformats/cube/",
                    epilog = f"Version info\n\nAuthor(s): {AUTHORS} \nVersion: {VERSION_NUMBER} \nDate: {VERSION_DATE} \n\n{COPYRIGHT}.") #pylint: disable=duplicate-code

    parser.add_argument("-v", "--verbose",                                  #pylint: disable=duplicate-code
                        action = "store_true",                              #pylint: disable=duplicate-code
                        help = "turn on verbose output mode")               #pylint: disable=duplicate-code

    parser.add_argument("-d", "--debug",                                    #pylint: disable=duplicate-code
                        action = "store_true",                              #pylint: disable=duplicate-code
                        default = False,                                    #pylint: disable=duplicate-code
                        help = "turn on debug mode (for developers only)")  #pylint: disable=duplicate-code

    parser.add_argument("-ha", "--hartree",
                        action = "store_true",
                        default = False,
                        help = "output potential in Hartee (default is eV)")

    parser.add_argument("aimpro_output_file",
                        nargs = 1,
                        help = "the AIM.sh.o* output file from an AIMPRO potential job")

    parser.add_argument("grid_vectors_input_file",
                        nargs = "?",
                        default = cio.DEFAULT_POT_INPUT_FILENAME,
                        help = f"input file, if none specified the default input file is used: {cio.DEFAULT_POT_INPUT_FILENAME}")

    args = parser.parse_args()
    verbose_output = args.verbose
    debug = args.debug
    use_hartree = args.hartree
    aimpro_infile = args.aimpro_output_file[0]
    grid_vec_infile = args.grid_vectors_input_file

    # Disable traceback when not in debug mode
    if not debug:
        sys.tracebacklimit = 0

    # Check provided files are valid
    if not Path(aimpro_infile).is_file():
        raise FileNotFoundError(f"no such file - '{aimpro_infile}'")
    if not Path(grid_vec_infile).is_file():
        raise FileNotFoundError(f"no such file - '{grid_vec_infile}'")

    # Check if AIMPRO file has correct naming convention, warn if not
    if not fnmatch.fnmatch(aimpro_infile ,"AIM.sh.o*"):
        print(f"Warning: {aimpro_infile} filename does not match the conventional AIMPRO output filename format (AIM.sh.o*), are you sure it is an AIMPRO output file?")

    if verbose_output:
        print("Verbose output mode enabled\n")
        print(f"Input file: {grid_vec_infile}\n")

    return grid_vec_infile, aimpro_infile

def get_atom_positions(aim_file: IO[str]) -> tuple[object, object]:
    """Uses Jon Goss's gres on the backend to extract atom positions in atomic units and the species index list.

    gres: https://www.staff.ncl.ac.uk/j.p.goss/MMG/Scripts/Output.html
    (Copyright (c) J.P. Goss 2024 All Rights Reserved.)

    Args:
        aim_file: AIMPRO output filename

    Returns:
        species_ind: array of species indexes (column 2 of OTB)
        atom_pos: atom positions in au (columns 5-9 of OTB)

    Raises:
        Warns if the files it needs to create already exist & backs up the existing ones
    """

    # Ensure we are able to create the xyz & otb files we temporarily need, backup exisiting ones and inform user
    if Path(f"xyz.{aim_file}.init").is_file():
        subprocess.run(f"mv xyz.{aim_file}.init xyz.{aim_file}.init.bak", shell=True, check=True)
        print(f"Warning: exisiting xyz.{aim_file}.init moved to xyz.{aim_file}.init.bak\n")

    if Path(f"otb.xyz.{aim_file}.init").is_file():
        subprocess.run(f"mv otb.xyz.{aim_file}.init otb.xyz.{aim_file}.init.bak", shell=True, check=True)
        print(f"Warning: exisiting otb.xyz.{aim_file}.init moved to otb.xyz.{aim_file}.init.bak\n")

    # Convert dat file to xyz
    subprocess.run(f"{CGRES_PATH} -einit {aim_file} 1> /dev/null", shell=True, check=True)

    # Convert xyz to otb, positions are now in atomic
    subprocess.run(f"{CGRES_PATH} -x2o xyz.{aim_file}.init 1> /dev/null", shell=True, check=True)

    # Read in otb values, they will be in the atomic reference frame
    result = m.read_otb(f"otb.xyz.{aim_file}.init")

    # Only need species_index and atom positions
    species_ind = result[0]
    atom_pos = result[2]

    # Remove temporary xyz & otb files
    subprocess.run(f"rm xyz.{aim_file}.init  otb.xyz.{aim_file}.init", shell=True, check=True)

    return species_ind, atom_pos

def read_aimpro_infile(aimpro_output_file: IO[str], grid_vectors_input_file: IO[str],         #pylint: disable=too-many-statements,too-many-locals
                       repeats: object, validation_grid_points: object,                       #pylint: disable=too-many-statements,too-many-locals
                       expected_lines_of_pot: int ) -> tuple[int, List[int], object, object]: #pylint: disable=too-many-statements,too-many-locals
    """Reads AIMPRO output file and extracts required data

    Args:
        aimpro_output_file: AIMPRO potential job output file name
        grid_vectors_input_file: : Filename of grid vectors input file
        repeats: number of repeats of each grid defining vector
        validation_grid_points: numpy array of regenerated grid points for validation of those in the AIMPRO file
        expected_lines_of_pot: expected number of grid points from validation data

    Returns:
        num_atoms: integer number of atoms (omitting ghost atoms)
        species_list: list of species symbols
        atom_pos: atom positions in au (omitting ghost atoms)
        potential_values: sum of the 3 potential values from aimpro_output_file

    Raises:
        Errors and exits if species with partial protons detected
        Errors and exits if number of grid points doesn't match those regenerated
        Errors and exits if grid points in AIMPRO file don't match the regenerated grid points from the grid vectors file
    """

    # Initialise proton num array
    species_proton_num_list = []

    # Initialise flags and values for the potential job
    potential_job_run = False
    in_potential_output = False
    ghost_species_found = False

    pot_count = 0

    aim_grid_points = np.zeros((expected_lines_of_pot, 3))
    aim_pot_values = np.zeros((expected_lines_of_pot, 1))

    # Flag if we are in the parts of the dat file we want to read, to avoid needless regexing
    dat_file_search = False
    in_pos_section = False

    # Open AIMPRO file, read line by line and extract data
    with open(aimpro_output_file, "r",  encoding="UTF-8") as infile:

        # Read whole file into memory - this is more memory costly but prevents code from being I/O bound for large files
        infile_lines = infile.read().splitlines()

        for line in infile_lines:

            # Skip comment lines
            if re.search(c.RE_AIM_COMMENT, line):
                continue

            # Update flags
            if c.RE_DAT_START in line:
                dat_file_search = True
            elif c.RE_DAT_END in line:
                dat_file_search = False
            elif c.RE_POSITIONS_START in line:
                in_pos_section = True
            elif c.RE_POSITIONS_END in line:
                in_pos_section = False

            # If flags tell us we are in dat section of AIM.sh.o*, Regex for the data we want
            if dat_file_search and not in_pos_section:

                partial_protons_search = re.search(c.RE_PARTIAL_PROTONS, line)

                # Error if species with partial protons detected
                if partial_protons_search:
                    raise Exception(f"unphysical input in {aimpro_output_file} - unable to parse {partial_protons_search.group(2)}\
                                        species with unphysical partial protons: {partial_protons_search.group(1)}")

                species_search = re.search(c.RE_SPECIES_EXTRACT, line)
                ghost_search = re.search(c.RE_GHOST, line)

                # Extract proton number of species and add to list in order (including GHOST atoms, we will filter them out later)
                if species_search:
                    species_proton_num_list.append(int(species_search.group(1)))

                    if verbose_output:
                        print(f"Species of type {species_search.group(2)} detected\n")

                if ghost_search:
                    species_proton_num_list.append(int(ghost_search.group(1)))
                    ghost_species_found = True

                    if verbose_output:
                        print(f"Species of type {ghost_search.group(2)} detected\n")

            # If we are outside dat region, we want to search for the potential data
            if not dat_file_search and not in_pos_section:

                pot_header_search = re.search(c.RE_POTENTIALS_HEADER, line)

                # Set flags to True to indicate this was a potential job, and we are in the potential region
                if not potential_job_run and not in_potential_output and pot_header_search:
                    potential_job_run = True
                    in_potential_output = True
                    continue

                # We are in the potential region, so record data
                if in_potential_output:

                    # Save grid points and all potential contributions (Columns 1-6)
                    split_line = line.split()

                    # If we have already read in as many lines of potential as we expect, check that the next line is empty.
                    # If it isn't there is more data than we are expecting and something has gone wrong
                    if pot_count == expected_lines_of_pot:
                        if split_line == []: # Line at the end of potential output is a new line char
                            in_potential_output = False
                            continue
                        raise Exception(f"more potential output detected in {aimpro_output_file} than expected from {grid_vectors_input_file}\
                                                - are you sure {grid_vectors_input_file} is the correct grid vectors input file?")

                    # Check that the line isn't empty, if it is raise an error as there are too few lines in the potential output
                    if pot_count < expected_lines_of_pot and split_line == []:
                        raise Exception(f"less potential output detected in {aimpro_output_file} than expected from {grid_vectors_input_file}\
                                            - are you sure {grid_vectors_input_file} is the correct grid vectors input file?")

                    # Map to floats
                    split_line[1:7] = map(float, split_line[1:7])

                    # Save positions
                    aim_grid_points[pot_count] = np.array(split_line[1:4])

                    # Save total potential, this will be in eV)
                    aim_pot_values[pot_count] = np.sum(np.array(split_line[4:7]))

                    # Increment count of number of lines we have read in
                    pot_count+=1

    # Error if we haven't detected a potential job run, looks like AIMPRO file wasn't a potential job output
    if not potential_job_run:
        raise Exception(f"no potential output detected in {aimpro_output_file} - are you sure it is an AIMPRO potential job output?")

    # Validate grid points, tols chosen according to truncation error in .4f format in AIMPRO outfile
    if not np.allclose(aim_grid_points, validation_grid_points, rtol=0, atol=1e-3):
        raise ValueError(f"Grid points in {aimpro_output_file} don't match those from {grid_vectors_input_file}\
                            - are you sure they are both using the same grid vectors?")

    if verbose_output:
        print(f"Grid points in {aimpro_output_file} validated\n")

    # Do unit conversion if required
    # The input from AIMPRO is in Hartree but the default output from this parser is eV
    # If the flag to use hartree is not specified, convert the potential values into eV
    if not use_hartree:
        aim_pot_values *= c.HA2EV

    # Reshape potential values so they are in the order dictated by the number of repeats of our grid vectors
    potential_values = aim_pot_values.reshape((repeats[0],repeats[1],repeats[2]))

    # Get species index list and atom positions in atomic units
    species_index, atom_positions = get_atom_positions(aimpro_output_file)

    # If we have ghost atoms, remove them from atomic positions
    if ghost_species_found:

        # Get index of ghost species, correcting OBO error due to OTB indexes
        ghost_index = species_proton_num_list.index(0)+1

        # Initialise incrementor
        i = 0
        for element in species_index:
            if element == ghost_index:

                # Delete element corresponding to ghost atom (end 0 signifies to delete row)
                species_index = np.delete(species_index, i, 0)
                atom_positions = np.delete(atom_positions, i, 0)

                # Inform user, correcting OBO error due to OTB indexes
                if verbose_output:
                    print(f"GHOST atom at atom index {i+1} omitted\n")

            # Increment
            i+=1

    # Now that we have removed any ghost atoms, we can count how many atoms we have
    num_atoms = atom_positions.shape[0]

    # Map species index to species proton number, subtracting one to correct for OBO error due to OTB indexes
    indexed_species_pn_list = [species_proton_num_list[element.item()-1] for element in species_index]

    return num_atoms, indexed_species_pn_list, atom_positions, potential_values

def generate_cubefile_data_string(reps: object, data: object) -> str:
    """Generates potential data string in cubefile format using string I/O stream.

    Args:
        reps: number of repeats of points in each dimension of the cubefile plotting volume
        data: cubefile data

    Returns:
        out_string.get_value(): cubefile data string from StringIO stream

    Raises:
        None
    """

    # Define StringIO stream
    out_string = StringIO()

    # Generate cubefile data format
    for ia in range(0, reps[0]):
        for ib in range(0, reps[1]):
            for ic in range(0, reps[2]):

                # Use 12.4e format not 13.5e format as python doesnt force a leading zero like fotran, this keeps data rounded to the same precision
                out_string.write(f" {data[ia, ib, ic]:12.4e}")

                # not ic == reps[2]-1 statment prevents an erronius double newline when reps[2] is a multiple of 6
                if ic % 6 == 5 and not ic == reps[2]-1:
                    out_string.write("\n")
            out_string.write("\n")

    if verbose_output:
        print("Generated cubefile volumetric data\n")

    return out_string.getvalue()

def write_cube_file(aimpro_output_file: IO[str], grid_vectors_input_file: IO[str],                       #pylint:disable=too-many-arguments,too-many-positional-arguments
                    num_atoms: int, indexed_species_pn_list: List[int], atom_pos: object,                #pylint:disable=too-many-arguments,too-many-positional-arguments
                    potential_values: object, repeats: object, vectors: object, origin: object) -> None: #pylint:disable=too-many-arguments,too-many-positional-arguments
    """Writes out potential data in cubefile format.

    Args:
        aimpro_output_file: AIMPRO potential job output file name
        grid_vectors_input_file: Grid vectors input filename/path
        num_atoms: integer number of atoms (omitting ghost atoms)
        indexed_species_pn_list: list of species proton numbers in the same order as the atomic positions (omiting ghost atoms)
        atom_pos: atom positions in au (omitting ghost atoms)
        potential_values: sum of the 3 potential values from aimpro_output_file
        repeats: number of repeats of each grid defining vector
        vectors: grid vectors
        origin: parallelepiped grid origin

    Returns:
        None

    Raises:
        None
    """

    # Open an outfile in cwd
    # (N.B. this is the directory aimpot2cube was called from, not were it lives)
    # Include units in filename
    if use_hartree:
        cube_output_file = aimpro_output_file + "_Ha" + cio.CUBE_OUTPUT_FILENAME
    else:
        cube_output_file = aimpro_output_file + "_eV" + cio.CUBE_OUTPUT_FILENAME

    outpath = Path.cwd() / cube_output_file

    if verbose_output:
        print(f"Writing output to file: {outpath}\n")

    # Get name of grid vectors file
    gv_file_name = PurePosixPath(grid_vectors_input_file).name

    # Open output file
    with open(outpath, "w", encoding="UTF-8") as outfile:

        # Fill the required comment lines in .cube file
        outfile.write("Cubefile created from AIMPRO output using aimpot2cube parser: Copyright (c) A Christison 2025 All Rights Reserved\n")

        if use_hartree:
            outfile.write(f"Contains the total potential from {aimpro_output_file} on the grid specified in {gv_file_name} in Hartree, positional data in Bohr\n")

        else:
            outfile.write(f"Contains the total potential from {aimpro_output_file} on the grid specified in {gv_file_name} in eV, positional data in Bohr\n")

        # Write number of atoms & position of origin
        outfile.write(f"{num_atoms:5d}{origin[0]:12.6f}{origin[1]:12.6f}{origin[2]:12.6f}\n")

         # Write out grid vectors and their repeats
        for i, value in enumerate(repeats):
            outfile.write(f"{value:5d}{vectors[i, 0]:12.6f}{vectors[i, 1]:12.6f}{vectors[i, 2]:12.6f}\n")

        # Write out atom proton number, their (unscreened) ionic charge & positions (in au)
        for i, value in enumerate(indexed_species_pn_list):
            outfile.write(f"{value:5d}{float(value):12.6f}{atom_pos[i, 0]:12.6f}{atom_pos[i, 1]:12.6f}{atom_pos[i, 2]:12.6f}\n")

        if verbose_output:
            print("Generating and writing cubefile volumetric data\n")

        # Write out volumetric potential data
        outfile.write(generate_cubefile_data_string(repeats, potential_values))

        if verbose_output:
            print("Written cubefile volumetric data\n")

        if verbose_output:
            print(f"Finished writing to: {outpath}\n")

def main() -> None:
    """Main method

    The main method is run when executing the prog.py file from console.

    This method is not designed to be called like a method from a module.
    """

    # Read cmd line for input files
    gv_infile, aim_infile = read_commmand_line()

    # Get repeats, vectors and generate grid points array from grid vectors input file
    rep, vec, orig = cio.read_grid_vectors(gv_infile, verbose_output)

    # Generate grid points from grid vectors, used later to validate grid in AIMPRO input file
    pts, num_pts = cio.generate_grid_points(rep, vec, orig, verbose_output)

    # Read in AIMPRO file and extract required data
    natoms, ind_species_pn, atpos, pots = read_aimpro_infile(aim_infile, gv_infile, rep, pts, num_pts)

    # Write cube file
    write_cube_file(aim_infile, gv_infile, natoms, ind_species_pn, atpos, pots, rep, vec, orig)

if __name__ == "__main__":
    main()
