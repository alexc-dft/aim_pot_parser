def main() -> None:

    # Read cmd line for input files
    gv_infile, aim_infile = read_commmand_line()

    # Get repeats, vectors and generate grid points dataframe from grid vectors input file
    rep, vec = cio.read_grid_vectors(gv_infile, verbose_output)

    # Generate grid points from grid vectors, used later to valadate grid in AIMPRO input file
    pts = generate_grid_points(rep,vec)

    # Read in AIMPRO file and extract required data
    natoms, species_pn, atpos, pots = read_aimpro_infile(aim_infile, gv_infile, rep, pts)

    # Write cube file
