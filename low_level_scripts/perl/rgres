    if(exists $data{'Charge Density option'}){print "\tCharge density type = $data{'Charge Density option'}\n";}
    if(exists $data{'Num. bcs'}){
	print "\t$data{'Num. bcs'} bond-centres detected".
	    ($data{'Num. bcs'}/$data{'Num. atoms'}>2.2?" (too many?)":"").
	    ($data{'Num. bcs'}/$data{'Num. atoms'}<1.8?" (too few?)":"").
	    ".\n";
    }elsif(exists $data{'Num. bcs detected'}){
	print "\t$data{'Num. bcs detected'} bond-centres detected [not included]".
	    ($data{'Num. bcs detected'}/$data{'Num. atoms'}>2.2?" (too many?)":"").
	    ($data{'Num. bcs detected'}/$data{'Num. atoms'}<1.8?" (too few?)":"").
	    ".\n";
    }
    if(exists $data{'Ecut'}){print "\tEcut = $data{'Ecut'} Ha, FFT grid = ",(join"x",@{$data{'FFT grid'}}),"\n";}
    
