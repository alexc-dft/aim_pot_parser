######################################################################
#### Output the xyz to file ##########################################
######################################################################
sub PrintXYZFile{
    #Input is the # of the iteration to output - if '-1' is passed
    #then all OTB are output.
    die "Wrong number of arguments supplied to PrintXYZFile\n" if $#_;
    my $iter = $_[0];
    if($iter!=-1&&($iter>$data{'OTBSet'}||$iter<1)){die "Passed an iteration number out of range ($iter) in PrintXYZFile\n"}
    if(!exists $data{'Species'}){die "Arrived in PrintXYZFile without detecting atomic species\n"}
    @species=split " ",$data{'Species'};
    print "!DBG! In PrintXYZFile\n" if $options{$invocation}{'debug'}[0];
    #Output all XYZ:
    if($iter<0){
	if(exists $data{'DiffPoint'} && !$options{$invocation}{v}[0]){
	    my $f=OpenOutput(XYZ,"new",$tag,"diff","Diffusion point iterations");
	    if(!$f){return}
	    my $i;
	    while(@{$data{'DiffPoint'}}){
		$i=shift@{$data{'DiffPoint'}};
		PrintXYZ($i);
	    }
	}else{
	    my $f=OpenOutput(XYZ,"new",$tag,"all","All iterations");
	    if(!$f){return}
	    my $i=1;while($i<=$data{'OTBSet'}){PrintXYZ($i);++$i}
	}
    }else{
	#Output specific XYZ:
	if($iter==1){
	    my $f=OpenOutput(XYZ,"new",$tag,"init","otb set $iter");	    
	    if(!$f){return}
	    PrintXYZ($iter);
	}
	elsif($iter==$data{'OTBSet'}){
	    my $f=OpenOutput(XYZ,"new",$tag,"final","otb set $iter");
	    if(!$f){return}
	    PrintXYZ($iter);
	}
	else{
	    my $f=OpenOutput(XYZ,"new",$tag,"init","otb set $iter");
	    if(!$f){return}
	    PrintXYZ($iter);
	}
    }
    #If requested, visualise the structure:
    if($options{$invocation}{'x'}[0]||
       $options{$invocation}{'xlast'}[0]||
       $options{$invocation}{'xinit'}[0]){
	push @{$system{'xyz'}},$f;
    }
}

