######################################################################
#### Get the evals from the output ###################################
######################################################################
sub GetEvals{
    if($#_){die "Wrong number of parameters passed to GetEvals ($#_!=1)\n"}
    my ($type,$esum)=($_[0],0);
    print "!DBG! Getting evals, type = $type\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list of evals
    if(($type eq "evals") or ($type eq "eval") or ($type eq "unoccupied") or ($type eq "k-point")){
	while(($_=<RES>)=~/^\s*-?\d{0,3}\.\d+/&&!eof){
	    next if /^\s*[!%]/;
	    if(/^\s*[\d\.\-]/){
		push @ { $data{'evals'}[$data{'EvalSet'}] },(split);
	    }
	}
    }elsif($data{"screened exchange"}&&$type eq "kpoint"){
	my ($t,$first,$outofthree)=(0,1,0);
	while(($_=<RES>)=~/^(\s*\d{1,3}\s|\s*-?\.?\d|\*\*\*\s+)/&&!eof){
	    next if /^\s*[!%]/;
	    if($_!~/\S/){last}
	    my @e=split;
	    if($first){if($e[0]=~/^\d+$/){$t=1}$first=0}
	    if($t==1&&$e[0]=~/^([0-9]+|\**)$/){		
		push @ { $data{'evals'}[$data{'EvalSet'}+$outofthree] },@e[1..$#e];
		$outofthree++;
		if($outofthree==3){$outofthree=0}
	    }elsif(!$t){
		push @ { $data{'evals'}[$data{'EvalSet'}+$outofthree] },@e;
		$outofthree++;
		if($outofthree==3){$outofthree=0}
	    }
	    if($t==1&&$e[0]=~/^-?[012]{0,1}\.\d+$/){		
		for(@e){$esum+=$_}
	    }
	}	
	$data{'EvalSet'}+=2;
    }elsif(($type eq "kpoint") or ($type eq "min") or ($type eq "max") or ($type eq "avg")){
	my ($t,$first)=(0,1);
	while(($_=<RES>)=~/^(\s*\d{1,3}\s|\s*-?\.?\d|\*\*\*\s+)/&&!eof){
	    next if /^\s*[!%]/;
	    if($_!~/\S/){last}
	    my @e=split;
	    if($first){if($e[0]=~/^\d+$/){$t=1}$first=0}
	    if($t==1&&$e[0]=~/^([0-9]+|\**)$/){		
		push @ { $data{'evals'}[$data{'EvalSet'}] },@e[1..$#e];
	    }elsif(!$t){
		push @ { $data{'evals'}[$data{'EvalSet'}] },@e;
	    }
	    if($t==1&&$e[0]=~/^-?[012]{0,1}\.\d+$/){		
		for(@e){$esum+=$_}
	    }
	}
	if(/ALLOCATED|time/){$data{"Esum format error"}=1}
    }
    if($esum){push @ { $data{"esum"} },$esum}
    if($options{$invocation}{'debug'}[0]){print "DGB: e-sum=$esum\n"}
}

######################################################################
#### Get the OTB from the output #####################################
######################################################################
sub GetOTB{
    print "!DBG! Getting OTB\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list of atom positions    
    while(<RES>){
	if(/(^\s*[!%]|^\s*$)/){
	    next;
	}elsif(
	    /^\s*\d+\s+\d+\s+-?\d+\s+-?\d+\s+-?\d+\s+-?\d+\s+-?(\d+\.?\d*|\d*\.\d+)\s+-?(\d+\.?\d*|\d*\.\d+)\s+-?(\d+\.?\d*|\d*\.\d+)\s*/){
	    push @ { $data{'otb'}[$data{'OTBSet'}] },$_;
	}elsif(
	    #Allow for scientific notation in the positions
	    /^\s*\d+\s+\d+\s+-?\d+\s+-?\d+\s+-?\d+\s+-?\d+\s+-?(\d+\.?\d*|\d*\.\d+)([ed][+-][0-9]+)?\s+-?(\d+\.?\d*|\d*\.\d+)([ed][+-][0-9]+)?\s+-?(\d+\.?\d*|\d*\.\d+)([ed][+-][0-9]+)?\s*/){
	    push @ { $data{'otb'}[$data{'OTBSet'}] },$_;
	}else{last;}
    }
    return @ { $data{'otb'}[$data{'OTBSet'}] } ;
}

######################################################################
#### Get the double derivitives from the output ######################
######################################################################
sub GetSpecies{
    print "!DBG! Getting species\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list
    while(($_=<RES>)!~/end/&&!eof){
	if(/^\s*[!%]/){next}
	if(/GHOST/){$data{'Species'}.=" X "}	   
	elsif(!/pot=/&&/\{([a-z]{1,2})/i){$data{'Species'}.=ucfirst($1)." ";}
	elsif(/\{pot\s*=\s*[\d\.]+-([a-z]{1,2})/i){$data{'Species'}.=ucfirst($1)." ";}
	elsif(/\{pot\s*=\s*([a-z]{1,2})/i){$data{'Species'}.=ucfirst($1)." ";}
	elsif(/\{\d+-([a-z]{1,2})/i){$data{'Species'}.=ucfirst($1)." ";}
#        if(/\{/&&/\s*(\S+)\s*/i){push @ { $data{'Basis'} },$1."\n";}
        if(/\{/&&/\s*(\S.*\S)\s*$/i){push @ { $data{'Basis'} },$1."\n";}
    }
    chop($data{'Species'});
    return;
}

######################################################################
#### Get the lattice definition from the data input ##################
######################################################################
sub GetLatticeVectors{
    print "!DBG! Getting lattice vector from output data\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list
    my $type = $_[0]; # P(rimitive) or C(onventional)
    #Sometimes (where the lattice is being detected) the data appears twice:
    if(exists $data{"d-latt $type"}){
	delete $data{"d-latt $type"};
	delete $data{"r-latt $type"};
    }
    while(($_=<RES>)!~/end/&&!eof){
	if(/^\s*[!%]/){next}
	chomp;
	my @a=(split);
	push @ { $data{"d-latt $type"} },@a[0..2];
	push @ { $data{"r-latt $type"} },@a[3..5];
	if( $#{  $data{"r-latt $type"} } == 8){last}
    }
    return;
}

