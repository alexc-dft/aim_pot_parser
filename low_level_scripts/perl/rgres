######################################################################
#### Convert a,b,c in relative to a,b,c in carts #####################
######################################################################
sub INT2XYZ{
    if($#_-11){die "\a\tFatal Error - wrong number of terms ($#_!=11) passed to \"INT2XYZ\"\n@_\n"}
    my @r=@_[0..2];
    my @vec=@_[3..11];
    my @xyz=(0,0,0);
    for $a (0..2){
	for $b (0..2){
	    $xyz[$a]+=$vec[$a+3*$b]*$r[$b];
	}
    }
    return(@xyz)
}

