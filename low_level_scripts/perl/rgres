######################################################################
#### Look for the available software for viewing xyz data ############
######################################################################
sub setXYZviewer{
    local(%progs);
    #Listed here are the known packages for visualisation, along with 
    #the options required for XYZ format input.  The index preceding
    #the program name indicates the order of preference should a platform
    #have more that one available option.
    %progs=(
	"5 minimol" =>" ",
	"2 xmakemol"=>" -f",
	"3 xmol"    =>" -readFormat xyz",
	"4 rasmol"  =>" -xyz",
	"1 jmol"    =>" "
	);
    #Assume the worst:
    $options{$invocation}{'xyz'}[0]="NONE";
    #Look for the program on the machine and return the complete 
    #command line:
    for(sort keys %progs){
	($p)=/^\d (.*)/;
	open T, "which $p|";
	if(($t)=($t=<T>)=~/^(\/.*)\n$/){
	    $options{$invocation}{'xyz'}[0]=$t.$progs{$_};
	    last;
	}
	close T;
    }
}

