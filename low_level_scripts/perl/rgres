	    for$k(0..  $# { $data{'esum'} }){
		$_= $ { $data{'esum'} } [$_];
		if($ThisSpin==1){$esum=$data{'Electronic levels (1)'}}else{$esum=$data{'Electronic levels (2)'}}
		@esum=split" ",$esum;
		$esum=$esum[0];if($data{'Spin'}==1){$esum*=2}
		for(2..$esum[1]+1){$esum+=$esum[$_]}
		if(abs($_-$esum)>0.001&&!$data{'Metallic'}){
		    $error++;
		    printf "\t\a**** Potential error in electron count ($ThisK)! Is this a metallic run? ****\n".
			"\t**** Found %9.4f electrons where there should be %9.4f! ****\n",$_,$esum;last
		}
		$ThisK++;
		if($ThisK>$data{'Num. k-points'}){
		    $ThisK=1;
		    if($data{'Spin'}==2&&$ThisSpin==1){$ThisSpin=2}else{$ThisSpin=1}
		}
	    }
	}
    }
    if(exists $data{"restart write"}||exists $data{"restart read"}){
	print "\tRestart Dump: ";
	if(exists $data{"restart read"}){print "READ",
					 ($data{"restart read"}eq"T"?
					  "(ovrrdpsns)":"");
					 if(exists $data{"restart write"}){print "/"}
	}
	if(exists $data{"restart write"}){print "WRITE"}
	print "\n";
    }
    if(exists $data{"RSB"}){print "\tReal space build (gvec cut-off = ",($data{"gvec_cutoff"}?$data{"gvec_cutoff"}:"default"),")\n"}
