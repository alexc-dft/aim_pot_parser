######################################################################
#### Convert xyz to otb format: ######################################
######################################################################
sub x2o{
    if($#_){die "Wrong no. of arguments passed to x2o\n";}
    my ($n,$file)=(0,$_[0]);
    my @r=();
    OpenInput($file);
    if(OpenOutput(OTB,"new",$tag,"","OTB output")){
	while(<RES>){
	    if($.==1){$natom=$_}
	    elsif($.==2){next}
	    else{
		@d=split;
		if($#d==3||$#d==4||$#d==6||$#d==7){
		    if(!exists $type{$d[0]}){$type{$d[0]}=++$ntype;$type2[$ntype]=$d[0]}
		    $species[++$n]=$d[0];
		    for(1..3){$d[$_]/=$const{'autoang'}}
		    push @{$r[$n]},@d[1..3];
		}else{
		    die "Error reading $file ($#d): is it really xyz?\n";
		}
	    }
	}
	# Check that the correct number has been read in:
	if($n-$natom){die "The XYZ and no. atoms read in does not agree\n";}
	# Now for the slow bit - what are the neighbours?
	# (Here we use the atomic radii of the two species multiplied by the
	# "bondfudge" factor.)
	# Work out the length-scale for the zoning of the structure...
	my $rmax=0;
	for my $i(1..$n){
	    my$t=$Atoms{$species[$i]}[1];
	    $rmax=($t>$rmax?$t:$rmax);
	}
	$rmax*=2*$options{$invocation}{'bondfudge'}[0];
        $rmax=($rmax?$rmax:1);
	
	# In practice, we compare squares of distances...
	my $r2max=$rmax*$rmax;
	
	my@address=();
	my@list=();
	# Allocate each atom to a zone...
	
	for $i (1..$n){
	    my @cell=();
	    for my $j (0..2){
		my $r=$r[$i][$j];
		$cell[$j]=($r>0?int($r/$rmax):int($r/$rmax-1));
	    }
	    @{$address[$i]}=@cell;
	    for my $c1 (-1,0,1){
		for my $c2 (-1,0,1){
		    for my $c3 (-1,0,1){
			push @{$list{$cell[0]+$c1}{$cell[1]+$c2}{$cell[2]+$c3}},$i
		    }
		}
	    }
	}
	
	# Now find the neighbours...
	for my $atom (1..$n){
	    my @list=@{$list{$address[$atom][0]}{$address[$atom][1]}{$address[$atom][2]}};
	    my $m=$#list;
	    my @r2=();
	    my %d2=();
	    for my $i (0..$m){
		next unless ($atom-$list[$i]); 
		for my $k (0..2){
		    $r2[$list[$i]]+=($r[$atom][$k]-$r[$list[$i]][$k])**2;
		}
		push @{$d2{$r2[$list[$i]]}},$list[$i];
	    }
	    my $r1=$Atoms{$species[$atom]}[1];
	    for my $j (sort bynumber keys %d2){		
		my $dist=sqrt($j);
		for my $k (sort bynumber @{$d2{$j}}){
		    my $r2=$Atoms{$species[$k]}[1];
		    my $test=$options{$invocation}{'bondfudge'}[0]
			*($r1+$r2);
		    if($test>=$dist){
			push @{$neighbours[$atom]},"$dist $k";
		    }
		}
	    }
	}
	print OTB "%".(join" ",@type2)."\n";
	for $i (1..$n){
	    #We need 4 neighbours:
	    my @tmp=();
	    my @n=(0,0,0,0);
	    for((BubbleSort(@{$neighbours[$i]}))[0..3]){push@tmp,(split)[1]}
	    @n=(@tmp,@n);
	    print OTB (FormatOTB(join" ",
				 $i,
				 $type{$species[$i]},
				 @n[0..3],
				 @{$r[$i]})
		);
	}
    }
    &FileSummary;
}

