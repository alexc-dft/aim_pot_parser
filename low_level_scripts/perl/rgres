		    $p[1],$p[2],0,
		    $p[3],$p[4],$p[5]],
	"trg-r" => [
	    $p[0],$p[1],$p[1],
	    $p[1],$p[0],$p[1],
	    $p[1],$p[1],$p[0],
	    $p[1],0,$p[0],
	    -0.5*$p[1],0.5*sqrt(3)*$p[1],$p[0],
	    -0.5*$p[1],-0.5*sqrt(3)*$p[1],$p[0],
	    $p[0]*sin($p[1]),0,$p[0]*cos($p[1]),
	    -0.5*$p[0]*sin($p[1]),0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
	    -0.5*$p[0]*sin($p[1]),-0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
	    $p[0]*(1+$p[1]),$p[0]*$p[1],$p[0]*$p[1],
	    $p[0]*$p[1],$p[0]*(1+$p[1]),$p[0]*$p[1],
	    $p[0]*$p[1],$p[0]*$p[1],$p[0]*(1+$p[1])
	],
	"hex-p" => [
	    $p[0],0,0,
	    -0.5*$p[0],0.5*sqrt(3)*$p[0],0,
	    0,0,$p[1],
	    0.5*$p[0],-0.5*sqrt(3)*$p[0],0,
	    0.5*$p[0],0.5*sqrt(3)*$p[0],0,
	    0,0,$p[1]
	]
	);
    
    #Pre-v57 definitions:
    @{ $primitive{"fcc"} }=(0.5*$p[0],0.5*$p[0],0,
			    0.5*$p[0],0,0.5*$p[0],
			    0,0.5*$p[0],0.5*$p[0]);
    @{ $conventional{"fcc"} }=(0.5*$p[0],0.5*$p[0],0,
			       0.5*$p[0],0,0.5*$p[0],
			       0,0.5*$p[0],0.5*$p[0]);
    @{ $primitive{"bcc"} }=@{ $primitive{"cub-i"} };
    @{ $conventional{"bcc"} }=@{ $primitive{"cub-i"} };
    @{ $primitive{"cubic"} }=@{ $primitive{"cub-p"} };
    @{ $conventional{"cubic"} }=@{ $primitive{"cub-p"} };
    @{ $primitive{"hex"} }=@{ $primitive{"hex-p"} }[0..8];
    #Turn "c/a" into "c":
    ${ $primitive{"hex"} }[8]*=$p[0];
    @{ $conventional{"hex"} }=@{ $primitive{"cub-p"} }[0..8];
    @{ $primitive{"rhomb"} }=(sqrt(3)*0.5*$p[0],-0.5*$p[0],0,
			      sqrt(3)*0.5*$p[0],0.5*$p[0],0,
    			      0,0,$p[1]*$p[0]);
    @{ $conventional{"rhomb"} }=(sqrt(3)*0.5*$p[0],-0.5*$p[0],0,
				 sqrt(3)*0.5*$p[0],0.5*$p[0],0,
				 0,0,$p[1]*$p[0]);
    
    
    my @vec=(@{$primitive{"$type"}}[(0+$orient*9)..(8+$orient*9)],@{$conventional{"$type"}}[(0+$orient*9)..(8+$orient*9)]);
    
    #Now apply the scaling:
    for $a (0..2){for $b (0..2){$vec[$b+$a*3]*=$scale[$a]}}
    
    return @vec;
    
}
