sub BubbleSort{
    my ($c,@a)=(1,@_);
    while($c<@a){my $p=1;while($p<@a){if($a[$p-1]>$a[$p]){@a[$p-1,$p]=@a[$p,$p-1];}$p++;}$c++}
    return @a;
}

