sub FileSummary{
    if($options{$invocation}{'q'}[0]>3){print "\n\t**FILES**\n"}
    # Work out the space needed for the descriptions:
    $l=11;
    for(keys %OpenFiles){
	next if $_ eq "RES";
	$l=(length($OpenFiles{$_}[1])>$l)?length($OpenFiles{$_}[1]):$l;
    }
    # Print them out:
    for $k (keys %OpenFiles){
	next if $k eq "RES";
	print" "x(8+$l-length($OpenFiles{$k}[1])),"$OpenFiles{$k}[1]: $OpenFiles{$k}[0]\n";
	# Also output additional comments if they exist:
	if($#{$OpenFiles{$k}}>1){
	    for(@ { $OpenFiles{$k} }[2..$#{$OpenFiles{$k}}]){print " "x($l-length($root{$k})-7),"\a!$root{$k} file creation: $_!\n";}
	}
    }
    #Now for comments for files NOT opened:
    for $k (keys %FileComments){
	for(@ { $FileComments{$k}}){
	    print " "x($l-length($root{$k})),"!$root{$k} ($k) file creation: $_!\n";
	}
    }
}

