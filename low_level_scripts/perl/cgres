######################################################################
#### A suite of routines to plot eigenvalue spectra ##################
######################################################################

######################################################################
#### The governing Homer routine that calls all subroutines: #########
######################################################################
sub Homer{
    print "!DBG! In Homer\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to Homer" if $#_;
    my $file = $_[0];
    # Set homer defaults:
    &HomerDefaults;
    # Read in the homer input file:
    my $set=0;$set=&HomerInput($file);if(!$set){die "No evals found\n"}    
    # Normalise from eV to normalised scale:
    &HomerNormalise();
    # Work out where the plot will go on the paper:
    &HomerPaper();
    # Now for the Plotting:
    $homerpsfile=&HomerPSOutput();
    # If invoked as Homer, give some output:
    if($invocation eq "Homer"){print "Postscript file generated: $homerpsfile\n"}
    #If requested, visualise the KS-levels:
    if($options{$invocation}{'xhomer'}){push @{$system{'postscript'}},$homerpsfile}
}

######################################################################
#### Work out in logical (normalised) units the paper dimensions: ####
######################################################################
sub HomerPaper{
    # Remember that in PS the scale is 72 points per inch!
    print "!DBG! In HomerPaper\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to HomerPaper ($#_)" if ($#_+1);
    # Work out the dimensions of the paper and graph area in cm:
    die "Plot area does not fit on the paper\n" if (!$homerdata{landscape}&&$homerdata{paper}[0]<$homerdata{"area"}[0] or $homerdata{paper}[1]<$homerdata{"area"}[1]);
    die "Plot area does not fit on the paper\n" if ($homerdata{landscape}&&$homerdata{paper}[0]<$homerdata{"area"}[1] or $homerdata{paper}[1]<$homerdata{"area"}[0]);
    # Scale the paper and plot area to "points":
    for(0..$#{$homerdata{paper}}){$homerdata{paper}[$_]*=$homerdata{"ps scale"};$homerdata{"area"}[$_]*=$homerdata{"ps scale"}}
    # Calculate the bottom left hand point of the graph:
    $homerdata{"ps offset"}[0]=0.5*($homerdata{paper}[0]-$homerdata{"area"}[0]);
    $homerdata{"ps offset"}[1]=0.5*($homerdata{paper}[1]-$homerdata{"area"}[1]);
    # Some debug output:
    print "!DBG! paper: $homerdata{paper}[0], $homerdata{paper}[1]\n" if $options{$invocation}{'debug'}[0];
    print "!DBG! graph: $homerdata{'area'}[0], $homerdata{'area'}[1]\n" if $options{$invocation}{'debug'}[0];
    print "!DBG! graph: $homerdata{'area'}[0], $homerdata{'area'}[1]\n" if $options{$invocation}{'debug'}[0];
}

######################################################################
#### Convert 'normalised' points to "point" points: ##################
######################################################################
sub Homer2Paper{
    # This works on pairs of numbers on the normalised scheme:
    my @p;
    my $m="Wrongly formated input to Homer2Paper\n";
    while(@_){
	my @b;
	for(0..1){unless(push @b,(shift)){die "$m"}}
	for(0..1){push @p,($homerdata{"area"}[$_]*shift(@b)+$homerdata{"ps offset"}[$_])}
    }
    return @p;
}

######################################################################
#### Set the font in the postscript file #############################
######################################################################
sub HomerSetFont{SetFont($font{$_[0]},$fontsize{$_[0]})}

######################################################################
#### Convert 'normalised' values to "point" values: ##################
######################################################################
sub eV2normal{
    print "!DBG! eV2normal input @_\n" if $options{$invocation}{debug}[0];
    my @p;
    while(@_){$_=shift(@_)-$homerdata{emin};$_/=$homerdata{range};push @p,$_}
    print "!DBG! eV2normal output @p\n" if $options{$invocation}{debug}[0];
    return @p;
}

######################################################################
#### Convert "point" values to 'normalised' values: ##################
######################################################################
sub normal2eV{
    print "!DBG! normal2eV input @_\n" if $options{$invocation}{debug}[0];
    my @p;
    while(@_){push @p,(shift(@_)*$homerdata{range}+$homerdata{emin})}
    print "!DBG! normal2eV output @p\n" if $options{$invocation}{debug}[0];
    return @p;
}

######################################################################
