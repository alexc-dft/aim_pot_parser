#Always start with the defaults:
&Defaults;

#The following line should be commented out to suppress immediate
#debugging output...
#$option{$invocation}{'debug'}[0]++;

#Get the command line options:
&SetSwitches;
&ProcessSwitches;

#Special cases:
if($invocation eq "o2x"||$options{$invocation}{'o2x'}[0]){&o2x($files[0]);&Exit()}
elsif($invocation eq "x2o"||$options{$invocation}{'x2o'}[0]){&x2o($files[0]);&Exit()}
elsif($options{$invocation}{'scale'}[0]){&scale($files[0],1);&Exit()}
elsif($options{$invocation}{'iscale'}[0]){&scale($files[0],-1);&Exit()}
elsif($invocation eq "analysis"||$options{$invocation}{'anal'}[0]){&anal($files[0]);&Exit()}
elsif($invocation eq "Homer"){&Homer($files[0]);&Exit()}
elsif($invocation eq "gres"){
    
    # Have we been asked to do something other than analyse dat/res files?
    if($options{$invocation}{'c'}[0]){&CleanUpDirectory;&Exit}
    
    #If we're accumulating Homer data...
    if($options{$invocation}{"allhomer"}[0]){$allhomerdata=OpenOutput(ALLHOMER,"force new","all",($options{$invocation}{'average'}[0]?"k-av":""),"accumulated homer input file")}
    
    
    # Then for each file, get the appropriate information:
    for $file (@files){
	
	&Initialise();
	
	# Try to determine the type of file we're looking at (eg AIMPRO output, xyz, otb, etc)
	if(&FileType($file) eq "otb"){
	    OpenInput($file);
	    while(<RES>){if($.==1&&/\%\s*(.*)$/){$data{"Species"}=$1}elsif(/^\s*\d+\s+(\d+)\s/){push @tmp,$1}}
	    $n=(sort bynumber @tmp)[$#tmp];
	    close(RES);
	    while((split" ",$data{"Species"})<$n){$data{"Species"}.=" X"}
	    OpenInput($file);
	    &GetOTB();
	    if($options{$invocation}{'bond'}[0]){&PrintBondCentreOTBFile()}
	}elsif(&FileType($file) eq "xyz"){
	    if($options{$invocation}{'bond'}[0]){}
	}elsif(&FileType($file) eq"aimpro"){
	    
	    #'GRES' results file:
	    &Gres($file);
	    
	    #If necessary, massage the data:
	    if(!$data{"Num. atoms"}){$data{"Num. atoms"}=$#{$data{'otb'}[1]}+1}
	    
	    #Convert lattice definitions into lattice vectors:
	    if(exists $data{"lattice type"}){
		if(exists $data{'d-latt P'}){
		    @{ $data{'d-latt P recon'} }= 
			LatticeDefinitions(
			    $data{"lattice type"},
			    $data{"lattice orient"},
			    $data{"lattice scale"},
			    (split" ",$data{"lattice params"})
			);
		    my $a=$b=$dp=0;
		    for(0..8){
			$a+=(${$data{'d-latt P'} }[$_]*${$data{'d-latt P'} }[$_]);
			$b+=(${$data{'d-latt P recon'} }[$_]*${$data{'d-latt P recon'} }[$_]);
			$dp+=(${$data{'d-latt P'} }[$_]*${$data{'d-latt P recon'} }[$_]);
		    }
		    $dp/=(sqrt($a)*sqrt($b));
		    if((1-$dp)>1e-5){
			printf "Internal check on lattice vectors has failed!\n a^2 = %10.5f, b^2 = %10.5f\n",$a, $b;
			printf "Dot product = %10.ef\n";$dp;
			printf "'d-latt P recon' (%d): \n%8.4f %8.4f %8.4f %8.4f %8.4f %8.4f %8.4f %8.4f %8.4f \n",1*@{$data{'d-latt P recon'}},@{$data{'d-latt P recon'}};
			printf "      'd-latt P' (%d): \n%8.4f %8.4f %8.4f %8.4f %8.4f %8.4f %8.4f %8.4f %8.4f \n",1*@{$data{'d-latt P'}},@{$data{'d-latt P'}};
			die;
			}
		}elsif(exists $data{"lattice type"}){
		    @{ $data{'d-latt P'} }= 
			LatticeDefinitions(
			    $data{"lattice type"},
			    $data{"lattice orient"},
			    $data{"lattice scale"},
			    (split" ",$data{"lattice params"})
			);
		    @{ $data{'d-latt C'} }= @{ $data{'d-latt P'} }[9..17];
		    @{ $data{'d-latt P'} }= @{ $data{'d-latt P'} }[0..8];
		}
	    }elsif(exists $data{"lattice vecs"}){
		@{ $data{"d-latt P"} }=(split" ",$data{"lattice vecs"});
		my $a=(split" ",$data{"lattice params"})[0];
		for(0..8){${$data{"d-latt P"}}[$_]*=$a}
	    }
	    
	    # Having got the information from the results file, output the
	    # information as requested
	    &Output();
	    
	}
	
	# Ensure that all the file handles are closed:
	&CloseAllFiles();
    }
    
    #If we need to, end the accummulation of homer data:
    if($options{$invocation}{'allhomer'}[0]){
	&PrintHOMERFile("allhomerend");
	&CloseAllFiles();
    }
}else{
    # If I get here then I've done something wrong...
    print "Apparently I know about '$invocation', but I don't know what to do next...\n";
    Exit();
}

# Run any system commands that result:
&System();

&Exit();

