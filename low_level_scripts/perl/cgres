######################################################################
#### Open the results file ###########################################
######################################################################
sub OpenInput{
    #I need to be given the name of the file to open:
    if($#_){die "Wrong no. of arguments for openinput!\n";}
    my $file=$_[0];$tag="";
    my $compressed=0;
    if($options{$invocation}{'debug'}[0]){print "!DBG! Opening input file\n";}
    #Check the file name for subdirectories and split off res or rest
    if($file=~m+^(.*)/(.*)+){$dir="$1/";$file=$2;}else{$dir="./";}
    if($file=~/^(.*)(\.gz|\.bz2|\.Z)$/){$file=$1;$compressed=$2;}
    if($file=~/^rest?\.(.*)$/){$tag=$1;}else{$tag=$file;}
    if($options{$invocation}{'debug'}[0]){
	print "!DBG! '$dir', '$file', '$compressed'\n";
    }
    if($compressed){
	if($compressed eq ".bz2"){
	    # Check that the compression method exists:
	    my $a=`which bzip2`;if($a=~/bzip2 not in/i){die "Cannot bzip2!\n"}
	    open(RES,"bzip2 -cd $dir$file.bz2|") or die"cannot open $dir$file\n";
	}else{
	    my $a=`which gzip`;if($a=~/gzip not in/i){die "Cannot gzip!\n"}
	    open(RES,"gzip -cd $dir$file|") or die"cannot open $dir$file\n";
	}
    }else{
	open(RES,"$dir$file") or die "cannot open $dir$file\n";
    }
    # Record the fact that the file has been opened
    @ { $OpenFiles{RES} } = ("$file","");
}

######################################################################
#### File rename to not overwrite ####################################
######################################################################
sub OpenOutput{
    #
    # Arguments are it's type (HANDLE), anything to add to the end of
    # the filename, and a description of the contents.  The hash
    # %OpenFiles contains this information.
    #
    die "Wrong number of arguments passed to OpenOutput\n" if ($#_-4);
    my ($h,$mode,$body,$t,$d)=@_;
    #The file type must be registered in the root hash:
    if(!exists $root{$h}){die "Error in OpenOutput: file type $h not defined in root hash\n";}
    $f="";
    #Test to see if one can write files where you are asking:
    my @destinations=("","$ENV{HOME}/scratch/","/tmp");
    if($options{$invocation}{'wo'}[0]){unshift @destinations,$options{$invocation}{'wo'}[0]}
    while(@destinations){
	$a=shift @destinations;
	if($a eq ""){$a="."}
	if(-w "$a"){last}
	# We've looked at the possibilities and found nowhere to write:
	if($#destinations==-1){
	    print "\a\t***Cannot write to any of the suggested directories***\n";
	    return 0;
	}
    }
    if($a ne $options{$invocation}{'wo'}[0] and $options{$invocation}{'wo'}[0]){
	print "\t\a***Cannot write to $options{$invocation}{'wo'}[0]: defaulting to $a***\n";
    }
    if($a ne "." and !$options{$invocation}{'wo'}[0]){
	print "\t\a***Cannot write to current directory: defaulting to $a***\n";
    }
    if($a eq "."){$options{$invocation}{'wo'}[0]=""}else{$options{$invocation}{'wo'}[0]=$a}
    #Now build the file name including the path where needed:
    if($options{$invocation}{'wo'}[0]){$f=$options{$invocation}{'wo'}[0]."/";}
    if($root{$h}){$f.=$root{$h}.".$body".($t?".$t":"")}else{$f.="$body".($t?".$t":"")}
    print "!DBG! file: $f, tail: $t, handle: $h, description: $d\n" if $options{$invocation}{debug}[0];
    #
    #If the -over flag is used, then do not preserve any existing
    #files.
    #
    if(!$options{$invocation}{'over'}[0] 
       && $mode ne "force new"
       && $mode ne "append"
	){$f.="+"while(-e "$f");}
    #
    if($mode eq "new" || $mode eq "force new"){
	open $h,">$f" or die "can't open $h: $f\n";
    }elsif($mode eq "append"){
	open $h,">>$f" or die "can't open $h: $f\n";
    }
    chmod 0666, $f;
    select $h;$|=1;select STDOUT;
    # Put into record that this file has been opened:
    @ { $OpenFiles{$h} } = ($f,$d);
    return $f;
}

######################################################################
#### Add information about output file (eg failure to write) #########
######################################################################
sub CommentOutput{
    #
    # Arguments are the HANDLE and the comment.
    #
    die "Wrong number of arguments sent to CommentOutput\n" if ($#_-1);
    my($h,$c)=@_;
    if(exists $OpenFiles{$h}){push @ {$OpenFiles{$h}},$c;}
    else{
	if(exists $FileComments{$h}){
	    push @{$FileComments{$h}},$c;
	}else{
	    $ { $FileComments{$h}} [0]=$c;
	}
    }
}

######################################################################
#### Close all open file handles (where appropriate?) ################
######################################################################
sub CloseAllFiles{while(($a,$b)=each %OpenFiles){close($a);delete $OpenFiles{$a}}}

######################################################################
#### Close all open file handles and exit for a clean getaway ########
######################################################################
sub Exit{
    &CloseAllFiles;
    if($ENV{HOSTNAME}=~/snufkin/){exit}
    if($ENV{HOSTNAME}=~/rhodes/){exit}
    if($ENV{HOSTNAME}=~/trueman/){exit}
    if($ENV{HOSTNAME}=~/polaris/){exit}
    if($ENV{HOSTNAME}=~/srif/){exit}
    if($ENV{HOSTNAME}=~/verity/){exit}
    #if($error){die "\n"}else{exit}
}

######################################################################
#### Convert otb to xyz format: ######################################
######################################################################
sub scale{
    if($#_-1){die "Wrong no. of arguments passed to scale\n";}
    my ($file,$type)=(@_[0..1]);
    my $otb="";
    OpenInput($file);
    if($options{$invocation}{'debug'}[0]){
	print "!DGB! scale factor = $options{$invocation}{'scale'}[0]\n";
	print "!DGB! iscale factor = $options{$invocation}{'iscale'}[0]\n";
    }
    if(!$options{$invocation}{'iscale'}[0]&&!$options{$invocation}{'scale'}[0]){die;}
    if($type==-1){$options{$invocation}{'scale'}[0]=1.0/$options{$invocation}{'iscale'}[0]}
    if($options{$invocation}{'debug'}[0]){print "!DGB! scale factor = $options{$invocation}{'scale'}[0]\n";}
    if(OpenOutput(SCA,"new",$tag,"scaled","scaled OTB output")){
	while(<RES>){
	    if(/^\s*[\#\%]/){$otb.=$_;next}	
	    else{push @ { $data{'otb'}[0] },$_}
	}
	ScaleOTB(0,$options{$invocation}{'scale'}[0]);
	print SCA $otb;
	for(@ { $data{'otb'}[0]}){print SCA (FormatOTB($_))}
	&FileSummary;
    }
}

######################################################################
#### Convert otb to xyz format: ######################################
######################################################################
sub o2x{
    if($#_){die "Wrong no. of arguments passed to o2x\n";}
    my $file=$_[0];
    my @species=();
    OpenInput($file);
    if(OpenOutput(XYZ,"new",$tag,"","XYZ output")){
	if($options{$invocation}{'s'}[0]){@species=split" ",$options{$invocation}{'s'}[0]}
	while(<RES>){
	    if($.==1&&/^\s*\%\s*([a-zA-Z].*)$/){@species=split" ",$1;next}
	    elsif(/^\s*[\#\%]/){next}
	    else{
		@d=split;
		if($#d==8){
		    $natom++;
		    for(6..8){
			$d[$_]*=$const{'autoang'};
		    }
		    if(!$species[$d[1]-1]){
			print STDERR "What is species $d[1]?";
			while(<STDIN>){if(/^([A-Z][a-z]?)$/){$species[$d[1]-1]=$1;last}}
		    }
		    $xyz.=FormatXYZ($species[$d[1]-1],@d[6..8]);
		}else{
		    die "Error reading $file: is it really otb?\n";
		}
	    }
	}
	print XYZ $natom."\n\n".$xyz;
    }
    &FileSummary;
}

######################################################################
#### Analyse otb and output with correct neighbour map: ##############
######################################################################
sub anal{
    if($#_){die "Wrong no. of arguments passed to anal\n";}
    # We need to know the species for an intelligent neighbour map:
    my @species=();
    if($options{$invocation}{'s'}[0]){@species=(split" ",$options{$invocation}{'s'}[0])}
    my ($header,$n,$file)=("",0,$_[0]);
    my @r=();
    OpenInput($file);
    if(OpenOutput(ANL,"new",$tag,"","neighbour map analysis output")){
	while(<RES>){
	    if($.==1&&/^\s*%(.*)$/){@species=(split" ",$1)}
	    if(/^\s*[%\#]/){$header.=$_;next}
	    else{
		@d=split;
		if($#d==8){
		    @{$b[++$n]}=@d[0..1];
		    while(!$species[$d[1]-1]){
			print "Atom type $d[1]?";chomp($_=<STDIN>);
			if(/^[a-z]{1,2}$/i){$species[$d[1]-1]=$_;$species[$d[1]-1]=ucfirst($species[$d[1]-1])}
		    }
		    push @{$r[$n]},@d[6..8];
		}else{
		    die "Error reading $file ($#d): is it really otb?\n";
		}
	    }
	}
	# Now for the slow bit - what are the neighbours?
	# (Here we use the atomic radii of the two species multiplied by the
	# "bondfudge" factor.)
	for $i (1..$n){
	    for $j($i+1..$n){
		my $dist=VectorLength(VectorDiff(@{$r[$i]},@{$r[$j]}));	    
		my $cutoff=(($Atoms{$species[$b[$i][1]-1]}[1]+$Atoms{$species[$b[$j][1]-1]}[1])
			    *$options{$invocation}{'bondfudge'}[0]);
		if($dist<$cutoff){
		    push @{$neighbours[$i]},"$dist $j";push @{$neighbours[$j]},"$dist $i";
		}
	    }	
	}    
	if($header ne ""){print ANL $header}else{print ANL "%".(join" ",@species)."\n";}
	for $i (1..$n){
	    #We need 4 neighbours:
	    my @n=(0,0,0,0);for((BubbleSort( @ { $neighbours[$i]}))[0..3]){unshift @n,(split)[1]}
	    print ANL (FormatOTB(join" ",(++$atom_number),$ { $b[$i]}[1],@n[0..3],@{$r[$i]}));	    
	}
    }
    &FileSummary;
}

######################################################################
#### Convert xyz to otb format: ######################################
######################################################################
sub x2o{
    if($#_){die "Wrong no. of arguments passed to x2o\n";}
    my ($n,$file)=(0,$_[0]);
    my @r=();
    OpenInput($file);
    if(OpenOutput(OTB,"new",$tag,"","OTB output")){
	while(<RES>){
	    if($.==1){$natom=$_}
	    elsif($.==2){next}
	    else{
		@d=split;
		if($#d==3||$#d==4||$#d==6||$#d==7){
		    if(!exists $type{$d[0]}){$type{$d[0]}=++$ntype;$type2[$ntype]=$d[0]}
		    $species[++$n]=$d[0];
		    for(1..3){$d[$_]/=$const{'autoang'}}
		    push @{$r[$n]},@d[1..3];
		}else{
		    die "Error reading $file ($#d): is it really xyz?\n";
		}
	    }
	}
	# Check that the correct number has been read in:
	if($n-$natom){die "The XYZ and no. atoms read in does not agree\n";}
	# Now for the slow bit - what are the neighbours?
	# (Here we use the atomic radii of the two species multiplied by the
	# "bondfudge" factor.)
	# Work out the length-scale for the zoning of the structure...
	my $rmax=0;
	for my $i(1..$n){
	    my$t=$Atoms{$species[$i]}[1];
	    $rmax=($t>$rmax?$t:$rmax);
	}
	$rmax*=2*$options{$invocation}{'bondfudge'}[0];
        $rmax=($rmax?$rmax:1);
	
	# In practice, we compare squares of distances...
	my $r2max=$rmax*$rmax;
	
	my@address=();
	my@list=();
	# Allocate each atom to a zone...
	
	for $i (1..$n){
	    my @cell=();
	    for my $j (0..2){
		my $r=$r[$i][$j];
		$cell[$j]=($r>0?int($r/$rmax):int($r/$rmax-1));
	    }
	    @{$address[$i]}=@cell;
	    for my $c1 (-1,0,1){
		for my $c2 (-1,0,1){
		    for my $c3 (-1,0,1){
			push @{$list{$cell[0]+$c1}{$cell[1]+$c2}{$cell[2]+$c3}},$i
		    }
		}
	    }
	}
	
	# Now find the neighbours...
	for my $atom (1..$n){
	    my @list=@{$list{$address[$atom][0]}{$address[$atom][1]}{$address[$atom][2]}};
	    my $m=$#list;
	    my @r2=();
	    my %d2=();
	    for my $i (0..$m){
		next unless ($atom-$list[$i]); 
		for my $k (0..2){
		    $r2[$list[$i]]+=($r[$atom][$k]-$r[$list[$i]][$k])**2;
		}
		push @{$d2{$r2[$list[$i]]}},$list[$i];
	    }
	    my $r1=$Atoms{$species[$atom]}[1];
	    for my $j (sort bynumber keys %d2){		
		my $dist=sqrt($j);
		for my $k (sort bynumber @{$d2{$j}}){
		    my $r2=$Atoms{$species[$k]}[1];
		    my $test=$options{$invocation}{'bondfudge'}[0]
			*($r1+$r2);
		    if($test>=$dist){
			push @{$neighbours[$atom]},"$dist $k";
		    }
		}
	    }
	}
	print OTB "%".(join" ",@type2)."\n";
	for $i (1..$n){
	    #We need 4 neighbours:
	    my @tmp=();
	    my @n=(0,0,0,0);
	    for((BubbleSort(@{$neighbours[$i]}))[0..3]){push@tmp,(split)[1]}
	    @n=(@tmp,@n);
	    print OTB (FormatOTB(join" ",
				 $i,
				 $type{$species[$i]},
				 @n[0..3],
				 @{$r[$i]})
		);
	}
    }
    &FileSummary;
}

######################################################################
#### Clean up the current directory from root hash info ##############
######################################################################
sub CleanUpDirectory{
    my @t=();
    #List files and colate those that match a gres output format:
    open LS, "ls -1|";
    while(<LS>){
	chomp;
	for $k (keys %root){
	    # We don't delete "dat" files!
	    next if /^dat\./;
	    # We do delete everything else:
	    if($_=~/^$root{$k}\./){chomp;push @t,$_}
	}
    }
    close(LS);
    #Have any files been found?
    if($#t!=-1){
	#List the files found and ask for confirmation to delete:
	print "Clean up:\n";for(@t){print "\t$_\n"}print "Delete (y/n)?";
	(<STDIN>=~/y/i)?unlink @t:print "Not removed\n";
    }else{
	print "Nothing detected to delete\n";
    }
}

