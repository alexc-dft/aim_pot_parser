sub PrintPDB{
    my @LV=();
    my $iter=$_[0];
    # Loop over the number of atoms in the cluster/cell
    my $n=0;my @d=();for(@{$data{'otb'}[$iter]}){
	if($iter==1){$d[++$n]=$_}
	else{$d[(split)[0]]=$_;}
    }
    # Specify the lattice vectors:
    if(exists $data{"d-latt P $iter"}){
	@LV=@{$data{"d-latt P $iter"}};
    }else{
	@LV=@{ $data{"d-latt P"} }
    }
    # Calculate the "a b c alpha beta gamma" values from the cartesian vectors:
    my $aa=sqrt($LV[0]**2+$LV[1]**2+$LV[2]**2);
    my $bb=sqrt($LV[3]**2+$LV[4]**2+$LV[5]**2);
