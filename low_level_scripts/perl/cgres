######################################################################
#### Output the reconstructed data file ##############################
######################################################################
sub PrintDATFile{
    print "!DBG! In PrintDATFile\n" if $options{$invocation}{'debug'}[0];
    #
    # Argumant passed to this routine is the number of the iteration
    # for which the otb is placed into the data file.
    #
    if($#_){die "Wrong number of argument passed to PrintDATFile\n";}
    my $iter=$_[0];
    if(!exists $data{'Data File'}){CommentOutput(DAT,"No data file info detected");return 0;}
    if(OpenOutput(DAT,"new",$tag,"","Reconstructed dat file")){
	if($ { $data{"Data File"} }[0] !~/begin\{data\}/){print DAT "/begin{data}\n";}
	for(@{$data{"Data File"}}){
	    print DAT $_,"\n";
	    last if /end\{data\}/;
	    # Positions:
	    if(/begin(\[.*\]|)\{(positions|cluster)\}/){
		for(@ {$data{'otb'}[$iter]}){print DAT (FormatOTB($_));}
#	    print DAT "\/end{$1}\n";
	    }
	    # Basis:
	    if(/begin\{(bhs|pseudo|hghpseudo)\}/){
		for(@ {$data{'Basis'}}){print DAT $_;}
#	    print DAT "\/end{$1}\n";
	    }			# 
	    # Lattice:
            if(/lattice\{/&&@{$data{'pars'}[$iter-1]}){
       print DAT "! pars at end of run are @{$data{'pars'}[$iter-1]}\n";
}
	    if(/begin.*\{lattice\}/){
            if(@{$data{'pars'}[$iter-1]}){
       print DAT "! pars at end of run are @{$data{'pars'}[$iter-1]}\n";
}
		print DAT $data{'lattice reconstruction'}."\n";
#	    print DAT "\/end{$1}\n";
	    }
	    # Symmetry:
	    if(/begin\{symmetry\}/){
		for(@ {$data{'Symmetry input'}}){print DAT $_;}
		print DAT "\/end{symmetry}\n";
	    }
	    # K-point sampling:
	    if(/begin.*\{sampling\}/){
		for(@ {$data{'sampling k-points'}}){print DAT (join" ",(split" ",$_)[0..3],"\n");}
#	    print DAT "\/end{sampling}\n";
	    }
	}
	# Just in case:
	print DAT "/end{data}\n";
    }
}

