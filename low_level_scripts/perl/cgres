			    }elsif($data{"unit definition"} eq "relative"){
				my$a1;
				if((split" ",$data{"lattice params"})[0]){
				    $a1=1/((split" ",$data{"lattice params"})[0]);
				}else{die "Failed in lattice repeat lattice output";}
				#Only rescale the first values (eg a data file):
				if($o>0){$a1=1}
				@v=@LV;
				@pos=(
				    $d[6]+$x*$v[0]*$a1+$y*$v[3]*$a1+$z*$v[6]*$a1,
				    $d[7]+$x*$v[1]*$a1+$y*$v[4]*$a1+$z*$v[7]*$a1,
				    $d[8]+$x*$v[2]*$a1+$y*$v[5]*$a1+$z*$v[8]*$a1);
			    }elsif($data{"unit definition"}=~/^(\d+|\.\d+)/){
				my$a1=1/$data{"unit definition"};
				#Only rescale the first values (eg a data file):
				if($o>0){$a1=1}
				@v=@LV;
				@pos=(
				    $d[6]+$x*$v[0]*$a1+$y*$v[3]*$a1+$z*$v[6]*$a1,
				    $d[7]+$x*$v[1]*$a1+$y*$v[4]*$a1+$z*$v[7]*$a1,
				    $d[8]+$x*$v[2]*$a1+$y*$v[5]*$a1+$z*$v[8]*$a1);
			    }
			    #Quick hack null neighbours array used here, -anal option can calculate for neighbours map
			    print RPT (FormatOTB(join" ",(++$natomtmp),$d[1],@null_neigh,@pos));
			}else{
			    # XYZ output:
			    my @xyz=(0,0,0);
			    if($data{"unit definition"} eq "int-p"
			       ||$data{"unit definition"} eq "internal"
				){
				@xyz=(INT2XYZ($d[6]+$x,$d[7]+$y,$d[8]+$z,@LV));
				for(0..2){$xyz[$_]*=$const{autoang}}
			    }elsif($data{"unit definition"} eq "int-c"){
				my @v=@{$data{'d-latt C'}};
				@xyz=(INT2XYZ($d[6],$d[7],$d[8],@v));
				my@xyz1=(INT2XYZ($x,$y,$z,@LV));
				for(0..2){$xyz[$_]=($xyz[$_]+$xyz1[$_])*$const{autoang}}
			    }elsif($data{"unit definition"} eq "atomic"
				   ||
				   ($data{"rescaled positions"} && $o!=1 &&
				    ($data{"unit definition"} ne "internal"))
				   ||
				   ($data{"unit definition"} eq "internal"
				    &&
				    $data{"restart options override-positions"}
				   )
				   ||
				   ($data{"unit definition"} =~ /\d/ && $o!=1)
				){
				my @v=@LV;
				@xyz=(
				    ($d[6]+$x*$v[0]+$y*$v[3]+$z*$v[6]),
				    ($d[7]+$x*$v[1]+$y*$v[4]+$z*$v[7]),
				    ($d[8]+$x*$v[2]+$y*$v[5]+$z*$v[8])
				    );	      
				for(0..2){$xyz[$_]*=$const{"autoang"}}
