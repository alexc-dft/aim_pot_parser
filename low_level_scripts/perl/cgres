######################################################################
#### Output the pretty formatted info as required ####################
######################################################################

sub Summary{
    print "$file:\n";
    
    # Atomic info:
    if($options{$invocation}{'q'}[0]>3){print "\n\t**ATOMS**\n";}
    if(exists $data{'Species'}){print "\tAtomic types (",$data{'Species'}=~tr/ / /+1,"): $data{'Species'}\n"}
    if(exists $data{'Num. atoms'}){print "\tThere are $data{'Num. atoms'} atoms.\n"}
    if(exists $data{'Basis type'}){print "\t$data{'Basis type'} pseudopotentials.\n"}
    if(exists $data{'Symmetry'}){print "\t$data{'Symmetry'}\n"}
    
    # Electronic data:
    if($options{$invocation}{'q'}[0]>3){print "\n\t**ELECTRONS**\n";}	
    if(exists $data{'Num. electrons'}){
	print "\tThere are $data{'Num. electrons'} electrons, spin ",(($data{'Spin'}==1)?"averaged":($data{"autospin"}?"polarised (***magnetic***)":"polarised")),".\n";
    }
    if(exists $data{'Spin'}){
	if($data{'Spin'}==1){
	    printf "\t\tAv: $data{'Electronic levels (1)'}%s\n",
	    ($data{'Metallic'}?(sprintf " (metallic %.4f)",$data{'mue 1'}):"");
	    @esum=split" ",$data{'Electronic levels (1)'};
	    $esum=$esum[0]*2;
	    for(2..$esum[1]+1){$esum+=$esum[$_]}
	    if(abs((eval(sprintf"%.0f",$esum))-$esum)>0.01&&!$data{"Esum format error"}){print"\t\t\a** Warning - non-integer no. of electrons (",abs(int($esum)-$esum),") **\n"}
	}else{
	    for(1..2){
		print "\t\t",(($_-1)?"Dn: ":"Up: ");
		printf "%s%s%s\n",
		($data{'autospin'}?
		 ($data{'muB'}?
		  ($data{'Num. electrons'}+($_-1?-1:1)*$data{'muB'})*0.5
		  :
		  "?"
		 )
		 :
		 $data{"Electronic levels ($_)"}),
		($data{'Metallic'}?(sprintf " (metallic %.4f)",$data{"mue $_"}):"");
		@esum=split" ",$data{"Electronic levels ($_)"};
		$esum=$esum[0];for(2..$esum[1]+1){$esum+=$esum[$_]}
		if(abs((eval(sprintf"%.0f",$esum))-$esum)>0.01&&!$data{"Esum format error"}){print"\t\t\a** Warning - non-integer no. of electrons (",abs(int($esum)-$esum),") **\n"}
	    }
	}
	#Check for esum error:
	$ThisK=1;
	$ThisSpin=1;
	if(@ { $data{'esum'} }){
	    for$k(0..  $# { $data{'esum'} }){
		$_= $ { $data{'esum'} } [$_];
		if($ThisSpin==1){$esum=$data{'Electronic levels (1)'}}else{$esum=$data{'Electronic levels (2)'}}
		@esum=split" ",$esum;
		$esum=$esum[0];if($data{'Spin'}==1){$esum*=2}
		for(2..$esum[1]+1){$esum+=$esum[$_]}
		if(abs($_-$esum)>0.001&&!$data{'Metallic'}){
		    $error++;
		    printf "\t\a**** Potential error in electron count ($ThisK)! Is this a metallic run? ****\n".
			"\t**** Found %9.4f electrons where there should be %9.4f! ****\n",$_,$esum;last
		}
		$ThisK++;
		if($ThisK>$data{'Num. k-points'}){
		    $ThisK=1;
		    if($data{'Spin'}==2&&$ThisSpin==1){$ThisSpin=2}else{$ThisSpin=1}
		}
	    }
	}
    }
    if(exists $data{"restart write"}||exists $data{"restart read"}){
	print "\tRestart Dump: ";
	if(exists $data{"restart read"}){print "READ",
					 ($data{"restart read"}eq"T"?
					  "(ovrrdpsns)":"");
					 if(exists $data{"restart write"}){print "/"}
	}
	if(exists $data{"restart write"}){print "WRITE"}
	print "\n";
    }
    if(exists $data{"RSB"}){print "\tReal space build (gvec cut-off = ",($data{"gvec_cutoff"}?$data{"gvec_cutoff"}:"default"),")\n"}
    if(exists $data{'Charge state'}){print "\tCharged system: $data{'Charge state'}\n"}
    if(exists $data{'EXC'}){print"\tFunctional = $data{EXC}\n"}
    if(exists $data{'Temperature'}){
	print "\tElectronic temperature = $data{'Temperature'} eV (".($data{'Smearing'}?$data{'Smearing'}:"Fermi").")".(($data{'Temperature'}>0.1&&$data{'Smearing'}ne"methpax")?"**too high?!**":"")."\n";
    }
    print "\tndim = ".($data{'Basis ndim'}?$data{'Basis ndim'}:"?").", nfit = ".($data{'Basis nfit'}?$data{'Basis nfit'}:"?")."\n";
    if(exists $data{'Charge Density option'}){print "\tCharge density type = $data{'Charge Density option'}\n";}
    if(exists $data{'Num. bcs'}){
	print "\t$data{'Num. bcs'} bond-centres detected".
	    ($data{'Num. bcs'}/$data{'Num. atoms'}>2.2?" (too many?)":"").
	    ($data{'Num. bcs'}/$data{'Num. atoms'}<1.8?" (too few?)":"").
	    ".\n";
    }elsif(exists $data{'Num. bcs detected'}){
	print "\t$data{'Num. bcs detected'} bond-centres detected [not included]".
	    ($data{'Num. bcs detected'}/$data{'Num. atoms'}>2.2?" (too many?)":"").
	    ($data{'Num. bcs detected'}/$data{'Num. atoms'}<1.8?" (too few?)":"").
	    ".\n";
    }
    if(exists $data{'Ecut'}){print "\tEcut = $data{'Ecut'} Ha, FFT grid = ",(join"x",@{$data{'FFT grid'}}),"\n";}
    
    # Job info:
    if($options{$invocation}{'q'}[0]>3){print "\n\t**JOB**\n";}	
    print "\t$data{'Optimise'}";
    if(exists $data{'Num. iteration'}){print " ($data{'Num. iteration'} iteration".($data{'Num. iteration'}-1?"s":"").")\n"}else{print ".\n"}
    if(exists $data{'NEB'}){
	printf "\tNEB: imgs=%d  passes=%d  nopt=%d  clmb=%d  pth=%s\n",
	$data{'NEB nimages'},$data{'NEB passes'},$data{'NEB nopt'},$data{'NEB climb'},$data{'NEB path'};
    }
    if(exists $data{'dds'}){
	print "\tEnergy double derivs: ",(join " ",@{$data{'dds'}});
	if($data{'DDS'}){print " (completed).\n"}
	elsif($data{'REC'}){
	    $a=$data{'REC'}=~s/deriv/deriv/g;
	    printf " (restart, %2.0f%s done).\n",$a*100/3./(split" ",$data{"2DD"}),'%';
	}
	else{print " (s'mt went wrong).\n"}
	    if($data{"2DD"}){
		my @a=(split" ",$data{"2DD"});
		my $trip=1;
		printf "\tUniques: %3d independent atom sites as follows\n\t        ",$#a+1;
		for(0..$#a){
		    printf" %3d",$a[$_];
		    if($_!=$#a && $trip==15){
			$trip=0;
			print"\n\t        ";
		    }
		    $trip++;
		}
		print "\n"
	    }
    }
    if(exists $data{'Mulliken analysis'}){print "\tMulliken analysis, levels $data{'Mulliken analysis'}\n"}
    if(exists $data{'optexp'}){
	print "\tExponent optimisation (types $data{'optexp'}): ",$#{$data{'ABC'}}+1," energies\n"
    }
    if(exists $data{"Bulk modulus au"}){
	printf "\tOptimised a0 = %8.6f au (egy=%.5f au)\n\tBulk modulus = %8.6f au (%.1f GPa)\n",$data{'Optimised a0'},
	$data{"Optimised energy"},$data{'Bulk modulus au'},$data{'Bulk modulus au'}*29410;
    }


    # Lattice data:
    if(exists $data{'lattice type'}||exists $data{'lattice vecs'}){
	if($options{$invocation}{'q'}[0]>3){print "\n\t**PERIODICITY**\n";}
	if($data{"lattice params"}){
	    $data{'lattice params'}=~s/\s+/ /g;
	    print "\tInput param(s) = $data{'lattice params'} au.".
		($data{'lattice type'}?" ($data{'lattice type'})\n":"\n");
	}else{
	    print "\tInput a0 = $data{'lattice a0'} au.".
		($data{'lattice type'}?" ($data{'lattice type'})\n":"\n");
	}
	if($data{'lattice vecs'}&&$options{$invocation}{'q'}[0]>2){
	    print "\tLattice Vectors:\n";
	    @d=(split" ",$data{'lattice vecs'});
	    print"\t\ta1 = (",$d[0],",",$d[1],",",$d[2],")\n";
	    print"\t\ta2 = (",$d[3],",",$d[4],",",$d[5],")\n";
	    print"\t\ta3 = (",$d[6],",",$d[7],",",$d[8],")\n";
	}
	print "\tBZ-sampling: $data{'Num. k-points'} k-point".
	    (($data{'Num. k-points'}>1)?"s":"").
	    (($data{'use_kpar'})?" (kpar)":"").
	    (($data{'k-points'}[0]=~/rel/)?" (rel)":"").
	    (($options{$invocation}{'q'}[0]>2)?":\n":".\n")
	    ;
	if($options{$invocation}{'q'}[0]>2){
	    for(0..($data{'Num. k-points'}-1)){print (join" ","\t\t",(split" ",$ { $data{'k-points'} }[$_])[0..3],"\n");}
	}
	if($#{ $data{'k-points'} }>=$data{'Num. k-points'}){
	    print "\tBandstructure Sampling (",$#{ $data{'k-points'} }-$data{'Num. k-points'}+1,
	    " point".(($#{ $data{'k-points'} }-$data{'Num. k-points'}>0)?"s":"").")\n";
	    if($options{$invocation}{'q'}[0]>3){
		for($data{'Num. k-points'}..$#{ $data{'k-points'} }){
		    print (join" ","\t\t",(split" ",$ { $data{'k-points'} }[$_])[0..3],"\n");
		}
	    }
	}
    }
    
    # Energy data:
    if($options{$invocation}{'q'}[0]>3){print "\n\t**ENERGY**\n";}	
    if($options{$invocation}{'q'}[0]>2){
	if(exists $data{'Final energy mc,'}){printf "\tFinal energy = %12.5f au (mid-S/C) [echerr=%.2e]\n",$data{'Final energy mc,'},$data{"echerr $data{'point data'}"}}
    }
    if(exists $data{'Final energy egy'}){printf "\tFinal energy = %12.5f au (S/C) [echerr=%.2e]\n",$data{'Final energy egy'},$data{"echerr "}}
    if(exists $data{'Final energy'}&&!exists $data{'Final energy egy'}){printf "\tFinal energy = %12.5f au (linemin)\n",$data{'Final energy'}}
    if($options{$invocation}{'q'}[0]>3){
	if(exists $data{'Energy components'}){
	    if($data{'Energy components'}[1]==$data{'Final energy'}){
		for(0..$#{$data{'Energy components'}}-1){
		    printf "\t      %6s = %12.5f au\n",$data{'Energy terms'}[$_],$data{'Energy components'}[$_+1];
		}
	    }}
    }
    @d=(split" ",$data{'Energy shiftt'});if(!$#d&&$d[0]=~/\*(.*)/){@d=($1,$1);}
    my $shifty=($data{"backward"}?0:($d[1]-$d[0]));
    my $thisenergy=0;
    if(exists $data{'Final energy'}&&!exists $data{'Final energy egy'}){
	$thisenergy=$data{'Final energy'};
    }elsif(exists $data{'Final energy egy'}){
	$thisenergy=$data{'Final energy egy'};
    }elsif(exists $data{'Final energy mc,'}){
	$thisenergy=$data{'Final energy mc,'};
    }
    if($#{$data{'NEB energies'}[$data{'NEB iter'}]}>-1){ 
	printf "\tNEB Energies (iter %d):\n\t\t%4s %12s %9s %9s %9s\n",$data{"NEB iter"},"img","E(Ha)","E_rel(eV)","F_image","F_raw";
	printf "\t\t%4s %12s %9s %9s %9s\n","====","============","=========","=========","=========";
	for my $e (@{$data{'NEB energies'}[$data{'NEB iter'}]}){
	    my@e=(split" ",$e);
	    printf "\t\t%4d %12.5f %9.5f %9.5f %9.5f %s\n",@e,($e[0]==$data{'NEB saddle image'}[$data{"NEB iter"}]?"<- saddle":"");
	}
    }else{
	printf "\t      SHIFTT(rel) += %9.5f au -> Etot = %11.5f au\n",
	$shifty,$shifty+$thisenergy;
    }
    if($data{"backward"}){
	printf "\t      Backward compatible energy  -> Ebak = %11.5f au\n",
	($d[1]-$d[0])+$thisenergy;
    }
    
    if(exists $data{'Energy change'}){
	print "\t      (last change = $data{'Energy change'} eV, rel egy = $data{'Relative energy'} eV)\n";
	print "\t      (max. force  =  $data{'Maximum force'} au)\n";
    }
    if(!exists $data{'mcmax'}){printf "\a\t*****Not self-consistent  [echerr=%.2e]*****\n",$data{"echerr $data{'point data'}"};$error++}
    
    # Error messages:
    
    if(exists $data{'not converged'}){print "\a\t*****Not converged iter: $data{'not converged'}*****\n"}
    if(exists $data{'DIIS warning'}){print "\a\t***** DIIS warning detected in output *****\n"}
    if($data{'starting banner'}>1){print "\a\t***** $data{'starting banner'} starting banners detected - probable concatenation of outputs *****\n"}
    
    # Gres settings:
    if($options{$invocation}{'q'}[0]>3){print "\n\t**GRES**\n";}
    if($options{$invocation}{'q'}[0]>2){
	print "\tXYZ viewer set to '$options{$invocation}{'xyz'}[0]'\n";
	print "\tFile over-writing ".($options{$invocation}{'over'}[0]?"enabled\n":"supressed\n");
    }
    
    #If there are more files, add a space:
    if($file ne $files[$#files]){print "\n"}
    
}

######################################################################
