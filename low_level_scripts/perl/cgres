######################################################################
#### Output the homer input file #####################################
######################################################################
sub PrintHOMERFile{
    if($#_){die "Wrong number of argument passed to PrintHOMERFile\n";}
    my $mode=$_[0];
    print "!DBG! In PrintHOMERFile\n" if $options{$invocation}{'debug'}[0];
    if(!exists $data{'evals'}){CommentOutput(HOMER,"No homer data found");return 0;}
    my ($header,$evaltop,$evalbottom,$footer)=("/begin{data}\n\n%%Global parameters:\n%/title{}\n%/subtitle{}\n%/energy label{}\n%/world{-20 0}\n%/shift{0}\n%/ticks{1 0.5}\n%/tol{0.05}\n%/labels{bottom}\n%/align{1}\n%/dividers\n%/bands{-1 1}\n%/VBmin{0.5}\n/stagger\n%/average symbol{circle}\n%/empty symbol{circle}\n%/filled symbol{circle}\n%/symbol size{9}\n%/white space{5}\n%/gap space{5}\n%/linewidth{1}\n%/landscape\n%/paper{21 29.7}\n%/area{12 20}\n%/decimals{1}\n%/labelfontsize{24}\n%/tickfontsize{16}\n%/titlefontsize{32}\n%/subtitlefontsize{24}\n\n%%Annotation:\n%/text{1 1 \"(a)\"}\n\n","/begin{evals}\n% /shift{}\n% /label{}\n% /updown{}\n% /rotatelabel\n","\n/end{evals}\n\n","/end{data}\n");    
    if($mode eq "all" || $mode eq "allhomerend"){
	$file=OpenOutput(ALLHOMER,"append","all",($options{$invocation}{'average'}[0]?"k-av":""),"accumulated homer input file");
	$HANDLE=ALLHOMER;
    }elsif($mode eq "one"){
	$file=OpenOutput(HOMER,"new",$tag,($options{$invocation}{'average'}[0]?"k-av":""),"homer input file");
	$HANDLE=HOMER;
    }
    if($file && ($mode eq "one"||$mode eq "all")){
	if($mode eq "one"|| ($mode eq "all" && !$allhomerstart) ){print $HANDLE $header;$allhomerstart++}
	if($mode eq "all"){print $HANDLE "%hom.$tag:\n"}
	# Where does one start?
	my $FirtSet=1;
	# The number of sets per interation =  #k-points x #spins
	my $interval=(exists $data{'Num. k-points'}?$data{'Num. k-points'}:1)*$data{"Spin"};
	if($data{"Compressed evals"}){$interval=3*$data{"Spin"}}
	if($data{"screened exchange"}){$interval=$data{'SX points'}*3}
	# If averaging over the k-points is requested, then build the averages:
	if($options{$invocation}{'average'}[0]&&$data{'Num. k-points'}>1){
	    my @temp2;shift @{$data{'evals'}};
	    my ($set,$k)=(1,0);
	    while(@{$data{'evals'}}){
		my @temp1 = shift @{$data{'evals'}};
		$k++;
		my $wght=(split" ",$ { $data{'k-points'}}[$k-1])[0];
		for (0..$#{$temp1[0]}) { $ { temp2[$set] }[$_]+=($wght*$temp1[0][$_]);}
		if($k==$data{'Num. k-points'}){
		    $k=0;
		    @{$data{'average evals'}[$set]}=@{$temp2[$set]};
		    $set++;
		}
	    }
	    @{$data{'evals'}}=@{$data{'average evals'}};
	    $data{'EvalSet'}=$set-1;
	    $interval=$data{'Spin'};
	}
	# Unless verbose output requested, only the last set is output:
	if(!$options{$invocation}{'v'}[0]){$FirstSet=$data{'EvalSet'}-$interval+1}
	# TAGE SX hack:
	if($data{"screened exchange"}&&!$options{$invocation}{'v'}[0]){
	    $FirstSet=$data{'EvalSet'}-($data{"SX points"}*3)+1;
	}
	if($options{$invocation}{'debug'}[0]){print "!DGB!: Firstset = $FirstSet, Evalset = $data{'EvalSet'}, interval = $interval\n"}
	# Loop over the sets:
	for($FirstSet..$data{'EvalSet'}){
	    # First find what point in the set of evals we're at:
	    # reduce by modulo $interval.
	    my ($partial,$a)=(0,$_);
	    if($data{"screened exchange"}){$a-=$data{"Num. k-points"}*$data{"Spin"}*2}
	    while($a>$interval){$a-=$interval;}
	    print $HANDLE $evaltop;
	    if($data{'Spin'}==2){
		# Spin polarised:
		# Is the current set nominally spin up or down?
		my $spin=(($a>$interval*0.5)?2:1);
		if($options{$invocation}{'debug'}[0]){print "!DBG! a=$a, spin=$spin\n"}
		# How many electrons are there?
		my @e=(split" ",$data{"Electronic levels ($spin)"});
		my $ne=$e[0];
		for(1..$e[1]){$ne+=$e[1+$_]}
		# Is this an integer (near enough)?
		my $ine=(sprintf "%4.0d",$ne);
		if(abs($ine-$ne)>0.001){
		    if($options{$invocation}{'debug'}[0]){print "!DBG! partial occupancy detected: $ine $ne\n";}
		    $partial=abs($ine-$ne);		
		}
		# Which leaves the remainder empty:
		my $empty=$#{$data{'evals'}[$_]}-$ne+1;
		# If there's a cock-up, we might spot it:
		if($empty<0){CommentOutput($HANDLE,"unexpected values in evals");}
		# Print out the necessary:
		if($partial){
		    if($options{$invocation}{'debug'}[0]){print "!DBG! partial occupancy detected: $ine $ne $partial\n";}		
		    printf $HANDLE "/partial{%d}\n",$partial;
		}
		printf $HANDLE "/empty{%d %d}\n",$empty,$empty;
		print $HANDLE "/".(($spin==2)?"down":"up")."{2}\n";
	    }else{
		# Spin averaged:
		my $empty; # =$#{$data{'evals'}[$_]}-$data{"Electronic levels (1)"}+1;
		# How many electrons are there?
#	    my @e=(split" ",$data{"Electronic levels (1)"});
#	    my $ne=2*$e[0]; # x 2 since spin averaged!
#	    for(1..$e[1]){$ne+=$e[1+$_]}
		my $ne=$data{"Num. electrons"};
		# Is this an integer (near enough)?
		my $ine=(sprintf "%4.0d",$ne*0.5);
		if(abs($ine-$ne*0.5)>0.001){
		    if($options{$invocation}{'debug'}[0]){print "!DBG! partial occupancy detected: $ine $ne\n";}
		    $partial=abs($ine*2-$ne);
		    $ne=$ine*2;
		}
		# Which leaves the remainder empty:
		$empty=$#{$data{'evals'}[$_]}-$ne*0.5+1;
		# If there's a cock-up, we might spot it:
		if($empty<0){CommentOutput($HANDLE,"unexpected values in evals");}
		# Print out the necessary:
		if($partial){
		    if($options{$invocation}{'debug'}[0]){print "!DBG! partial occupancy detected: $ine $ne $partial\n";}		
		    printf $HANDLE "/partial{%d}\n",$partial;
		}
		print $HANDLE "/empty{$empty $empty}\n";
		print $HANDLE "/av{2}\n";
	    }
	    print $HANDLE "/levels{",$#{$data{'evals'}[$_]}+1,"}\n";
	    my $c=0;
	    for(@{$data{'evals'}[$_]}){
		printf $HANDLE " %8.4f",$_;
		if($c++==7){$c=0;print $HANDLE "\n"}
	    }
	    print $HANDLE $evalbottom;
	    
	}
    }
    if($mode eq "one" || $mode eq "allhomerend"){print $HANDLE $footer;}
    return $file;
}

