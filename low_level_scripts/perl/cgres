	"3 ggv" =>" ",
	"4 evince" =>" ",
	"1 display" =>" ",
	"6 ghostscript" =>" "
	);
    #Assume the worst:
    $options{$invocation}{'postscript'}[0]="NONE";
    #Look for the program on the machine and return the complete 
    #command line:
    for(sort keys %progs){
	($p)=/^\d (.*)/;
	open T, "which $p|";
	if(($t)=($t=<T>)=~/^(\/.*)\n$/){
	    $options{$invocation}{'postscript'}[0]=$t.$progs{$_};
	    last;
	}
	close T;
    }
}

######################################################################
#### Check that the invocation is known ##############################
######################################################################
sub Invocation{
    $invocation="";
    for(keys %options){	$invocation = $_ if $0 =~ /(\/|^)$_$/ }
    ##############################################
    ############### QUICK HACK: ##################
    ##############################################
    if($0 =~ /(\/|^)new_gres/){$invocation="gres"}
    if($0 =~ /(\/|^)aimgres/){$invocation="gres"}
    if($0 =~ /(\/|^)cgres/){$invocation="gres"}
    ##############################################
    die "Don't know how to run '$0'\n" if !$invocation;
}

######################################################################
#### Set switches hash from command line options #####################
######################################################################
sub SetSwitches{
    print "!DBG! In SetSwitches\n" if $options{$invocation}{'debug'}[0];
    while($_=shift @ARGV){
	#Switches:
	if(($a)=$_=~/^-(.*)$/){
	    die "Unknown option -$a\n" if !CheckOption($a);
	    if($options{$invocation}{'debug'}[0]){print "!DBG! Option -$a accepted\n";}
	    die "Can't set option -$a\n" if !SetOption($a);
	    if($options{$invocation}{'debug'}[0]){print "!DBG! Option -$a set to $options{$invocation}{$a}[0]\n";}
	}	
	#Files:
	else{if(-e $_){push @files,$_;}else{die "No such file: '$_'\n";}}
    }
}

######################################################################
#### Process the switches for combinations and global effects ########
######################################################################
sub ProcessSwitches{
    # Globals:
    if($options{$invocation}{h}[0]){&Help;}
    
    if($invocation eq "gres"){
	if($options{$invocation}{V}[0]){print "Version $const{'version'}\n";&Exit}
	
	# Combinations have extra effects:
	if($options{$invocation}{o}[0]&&$options{$invocation}{v}[0]){
	    $options{$invocation}{oinit}[0]=$options{$invocation}{olast}[0]=1;
	}
	if($options{$invocation}{v}[0]){$options{$invocation}{q}[0]=4;}
	
	# Some options might not require any files:
	if($options{$invocation}{'c'}[0]){return;}
	
	# ...others only want a single xyz or otb file:
	if($options{$invocation}{'scale'}[0] or
	   $options{$invocation}{'o2x'}[0] or 
	   $options{$invocation}{'anal'}[0] or 
	   $options{$invocation}{'x2o'}[0]){
	    if($#files){die "The option chosen requires a single file.\n"}
	    return;
	}
	
	# Otherwise, are there any files?
	if(!($#files+1)){print "No files provided!\n";&Help}
    }elsif($invocation eq "o2x"){
	if(!($#files+1)){print "No files provided!\n";&Help}
	if($#files){&Help}
    }elsif($invocation eq "x2o"){
	if(!($#files+1)){print "No files provided!\n";&Help}
	if($#files){&Help}
    }elsif($invocation eq "analysis"){
	if(!($#files+1)){print "No files provided!\n";&Help}
	if($#files){&Help}
    }elsif($invocation eq "Homer"){
	if(!($#files+1)){print "No files provided!\n";&Help}
	if($#files){&Help}
    }
}

######################################################################
#### Help output from the options hash ###############################
######################################################################
sub Help{
    print "Version $const{'version'}\nUsage: $options{$invocation}{USAGE}[2]\n$invocation options:\n";
    $l=0;for(keys %{$options{$invocation}}){
	next if $_ eq "USAGE";	               #Ignore usage info
	next if !$options{$invocation}{$_}[3]; #Ignore unsupported options
	$l=(length($_)>$l)?length($_):$l;
    } 
    for(sort keys %{$options{$invocation}}){
	next if $_ eq "USAGE";	               #Ignore usage info
	next if !$options{$invocation}{$_}[3]; #Ignore unsupported options
	print" "x(1+$l-length()),"-$_ ... $options{$invocation}{$_}[2]\n";
    }
    &Exit;
}

######################################################################
#### Check options hash for the one we've just been handed ###########
######################################################################
sub CheckOption{
    local $option=$_[0];
    die "Too many arguments given to 'CheckOption'" if $#_;
    for(keys % { $options{$invocation} }){return 1 if $_ eq $option and $options{$invocation}{$_[0]}[3];}
    # Check for maintainance flag (0=unsupported, 1=supported)
    for(keys % { $options{$invocation} }){
	if ($_ eq $option and !$options{$invocation}{$_[0]}[3]){ die "$_: Option not supported :-)\n";}
    }
    return 0;
}

######################################################################
#### Toggle binary switch / set a variable switch ####################
######################################################################
sub SetOption{
    die "Too many arguments given to 'SetOption'" if $#_;
    # Toggle Binary switch:
    if($options{$invocation}{$_[0]}[1] eq "bin"){$options{$invocation}{$_[0]}[0]=($options{$invocation}{$_[0]}[0])?0:1;return 1;}
    # Try to set a variable:
    elsif($options{$invocation}{$_[0]}[1] =~/^va([1-9])$/){
	#nval is the number of values that follow the command line option:
	my $nval=$1;$options{$invocation}{$_[0]}[0]="";
	while($nval){
	    if($_ = shift @ARGV){
		die "Argument(s) missing for option -$_[0]?\n" if /^-/;
		$options{$invocation}{$_[0]}[0].=($_.($nval>1?",":""));
	    }elsif($_ eq "0"){
		$options{$invocation}{$_[0]}[0].=("0".($nval>1?",":""));
	    }else{
		die"Argument(s) missing for option -$_[0]\n";
	    }
	    
	    --$nval;
	}
	return 1;
    }else{
	die "\aERROR: Major failure in setting options\n";
    }
}

######################################################################
#### Grep information from results file ##############################
######################################################################
sub Gres{
    #I need the name of the file to gres:
    if($#_){die "Wrong number of arguments supplied to Gres ($#_!=0)\n";}
    my $f=$_[0];
    OpenInput($f);
    if($options{$invocation}{'debug'}[0]){print "!DBG! At last... GRES\n";}    
    while(<RES>){
	# Ignore comment lines:
	next if /^\s*[%\#!]/;
	# - Run subroutines first - they may have data at the end that is still needed:
	if(/\*   dat   \*/){$xxx=1;$_=<RES>;$_=<RES>;next}
	if(/^[\s\/]*begin\{symmetry\}/){push @ { $data{'Data File'}},$_;$data{'Symmetry'}="Symmetry turned on";&GetSymmetry}	
	if(/EVAL/){$data{"SX points"}=0}
	while(/(evals|eval|unoccupied|k-point|kpoint|min energy|max energy|avg energy)/){
	    if($options{$invocation}{'debug'}[0]){print "!DBG! EVALS: $_\n";}    
	    last if /Special|folded|reduced|dE_/;
	    last if /E_sx|E_i/;
	    last if /WAVEFUNCTION/;
	    last if /analysis\{/;
	    $data{"SX points"}++;
	    my $t=$1;
	    if(/spin, kpoint :\s+(\d+)\s+(\d+)/){
		$data{'Num. k-points'}=$2;
		if($data{'Metallic'}){$data{"mue $1"}=(split)[7]}
	    }
	    if(/spin, (min|max|avg)/){
		$t=$1;$data{"Compressed evals"}=1;
		if($data{'Metallic'}){
		    my$s=(split)[5];
		    if($data{'Metallic'}){$data{"mue $s"}=(split)[6]}
		}
	    }
	    last if /nominally/;
	    if($t!~/unocc/){$data{'EvalSet'}++;}
	    &GetEvals($t);	    
	}
	if(/(positions\}|positions of atoms|cluster\})/ and !/(end|charge|restart)/){
	    if(/units=/){$data{"rescaled positions"}=0}
	    if(/\[atomic\]/){$data{'units'}="Positions given in a.u.";$data{"unit definition"}="atomic";}
	    elsif(/\[ang/){$data{'units'}="Positions given in Angstrom";$data{"unit definition"}="ang";}
	    elsif(/\[int-p/){$data{'units'}="Positions given by internal (int-p)";$data{"unit definition"}="int-p"}
	    elsif(/\[int-c/){$data{'units'}="Positions given by internal (int-c)";$data{"unit definition"}="int-c"}
	    elsif(/\[internal/){$data{'units'}="Positions given by internal";$data{"unit definition"}="internal"}
	    elsif(/\[(.*)\]/){$data{'units'}="Positions given by a scaling factor ($1)";$data{"unit definition"}=$1}
	    elsif(/begin\{pos/i&&!$data{"unit definition"}){$data{'units'}="Initial positions given by a0";$data{"unit definition"}="relative"}
	    elsif(/begin\{clust/i&&!$data{"unit definition"}){$data{'units'}="Initial positions in a.u.";$data{"unit definition"}="atomic"}
	    if(/(begin)/){push @ { $data{'Data File'}},$_}
	    $data{'OTBSet'}++;
	    if($options{$invocation}{'debug'}[0]){chomp;print "!DBG! Incrementing OTBSet: line $. ($data{'OTBSet'}), '$_'\n";}
	    &GetOTB();
	}
	if(/begin.*\{lattice\}/){push @ { $data{'Data File'}},$_;&GetLattice}
	while(/wavefunction coef/){$data{'WFNcoef'}++;&GetWFN}
	while(/DIPOLE/){$data{'DipoleSet'}++;&GetDipole}
	if(/use_kpar/){$data{use_kpar}=1}
	if(/row of dynamical matrix/){&GetDDS}
	if(/parameter\{.*exc\s*=\s*([a-z]+)\s*[\s,\}]/){$data{EXC}=$1}
	if(/parameter\{.*use_real_space_build.*\}/){$data{RSB}=1}
	if(/parameter\{.*gvec_cutoff\s*=\s*(.*)?\}/){$data{gvec_cutoff}=$1}
	if(/begin\{(bhs|pseudo|hghpseudo)\}/){
	    push @ { $data{'Data File'}},$_;
	    if($1 eq "bhs"){
		$data{'Basis type'}="Analytical";
	    }elsif($1 eq "pseudo"){
		$data{'Basis type'}="Tabulated";
	    }elsif($1 eq "hghpseudo"){
		$data{'Basis type'}="HGH";
	    }
	    &GetSpecies;
	}
	if(/2DD TO BE CALCULATED/){&Get2DD}
	if(/begin.*sampling/){push @ { $data{'Data File'}},$_;&GetSampling}
	if(/The following bond centres have been identified/){&GetBondCentrePositions(0)}
	if(/the following bond centres have been included/){&GetBondCentrePositions(1)}	
	##########################################
	# Now for the easier to get information: #
	##########################################
	chomp;
	# - Restart Dump information
	if(/DONE READING OF RESTART DUMP  (?)/){$data{'restart read'}=$1}
	if(/WRITTEN RESTART DUMP/){$data{'restart write'}++}
	# - TAGE screened exchange
	if(/Here comes screended EXCHANGE/){$data{"screened exchange"}=1;next}
	# - The starting banner (some versions)
	if(/ABINITIO/){$data{"starting banner"}++;next}
	# - Reproduction of data file:
	if(/^\s*(\/.*)/||$xxx){push @ { $data{'Data File'}},$_;}  #No next here!!!
	if(/end\{data\}/){$xxx=0}
	# - Symmetry: 
	if(/\s*Isogonal point group: (\w+) /){$data{'Group'}="(".$1.")";next}	
	if(/\s*MATRICES :\s*(\d+)/){$data{'Symmetry'}="$1 symmetry operation".($1-1?"s":"")." detected".($data{'Group'}?" $data{'Group'}":"").".";next}	
	if(/symmetry of molecule identified as (\S+)/||/symmetry identified as (\S+)/){$data{'Symmetry'}="Molecular symmetry set to '$1'.";next}
	if(/spherical top|symmetric top/){$data{'Symmetry'}="\aSYMMETRIC TOP";next}
	# - Complete output?
	if(/time : end\s+\d+\s+(\S+)\s/){$data{'Completed'}="Apparently ($1s)";next}
	# - Self-consistency and total energy:
	if(/not converged/){$data{'not converged'}.=(($data{'Num. iteration'}?$data{'Num. iteration'}:0)." ");next}
	if(/mcmax\s+(\d+)/){$data{'mcmax'}=$1;delete $data{'Final energy mc,'};next}
	if(/point ([12]) /){$data{'point data'}=$1;next}
	if(/mc,/||/etot,echerr/){
	    print "!DBG! ETOT located ($_)\n" if $options{$invocation}{'debug'}[0];
	    if(exists $data{'Final energy egy'}&&!$data{'point data'}){delete $data{'Final energy egy'}}
	    $data{'Final energy mc,'}=(split)[2];
	    $data{"echerr $data{'point data'}"}=(split)[3];
	    next;
	}
	if(/egy /){
	    if($data{'mcmax'}){delete $data{'mcmax'}}
	    @{$data{'Energy components'}}=(split);
	    $data{'Final energy egy'}=$data{'Energy components'}[1];
	    delete $data{'Final energy mc,'};
	    next;
	}
	if(/etot/){@{$data{'Energy terms'}}=(split",",$_);next}
	if(/ SHIFTT\(ch\/neut\):(.*)$/){$data{'Energy shiftt'}=$1;$data{'Energy shiftt'}=~s/,//g;}
	if(/ To get backward compatible energy, add: (.*)$/){$data{"backward"}++;$data{"Energy shiftt"}="0 $1";}
	if(/ To get backward compatible energy, subtract: (.*)$/){$data{"backward"}++;$data{"Energy shiftt"}="$1 0";}
	# - Optimisation	
	if(/atoms to be optimised :(.*)$/){$data{'Optimise'}=eval($1)." atoms optimised";next}
	if(/^\s*latconst/){$data{'Optimise'}="Isotropic lattice constant optimisation";next}
	if(/all atoms to be optimised/){$data{'Optimise'}="All atoms optimised";next}
	if(/atoms to be optimised :\s+(\d+)/){my $o;$_="";while(($_=<RES>)=~/^\s*\d+/){$o.=$_};@{$data{'Optimised atoms'}}=split " ",$o;next}
	if(/optimise\{(.*)\}/){my$o=$1;if($o=~/all/){$data{'Optimise'}="All atoms optimised"}else{@{$data{'Optimised atoms'}}=split " ",$o};next}
	if(/iteration :/){$data{'Num. iteration'}++;delete $data{'point data'};next}
	if(/final energy.*\s(\S+)$/){
	    $data{'Final energy'}=$1;
	    delete $data{'Final energy egy'};
	    next;
	}
	if(/final gradient.*\s(\S+)$/){$data{'Final gradient'}=$1;next}
	if(/maximum move\s*(\S+)$/){$data{'Maximum move'}=$1;next}
	if(/maximum at move \(au\)\s*(\S+)$/){$data{'Maximum move'}=$1;next}
	if(/maximum lv move \(au\)\s*(\S+)$/){$data{'Maximum lv move'}=$1;next}
	if(/maximum force.*\s(\S+)$/){$data{'Maximum force'}=$1;next}
	if(/energy change.*\s(\S+)$/){$data{'Energy change'}=eval($1);next}
	if(/relative energy.*\s(\S+)$/){$a=$1;$a=~s/D/e/;$data{'Relative energy'}=eval($a);next}
	if(/( diffusion point |DIF POINT)/){push @{$data{'DiffPoint'}},$data{'OTBSet'};next}
	if(/^[abc]ucl:(.*)$/){
	    my $i=$data{'OTBSet'}+1;
	    push @{$data{"d-latt P $i"}},(split" ",$1);next;
	}
	if(/^pars:(.*)$/){
	    push @{$data{'pars'}[$data{'OTBSet'}]},(split" ",$1);next;
	}	
	# - NEB runs
	if(/Nudged Elastic Band Diffusion Run/){$data{'NEB'}=1;next}
	if(/Number of Images\s+=\s*(\d+)$/){$data{'NEB nimages'}=$1;next}
	if(/Number of Passes\s+=\s*(\d+)$/){$data{'NEB passes'}=$1;next}
	if(/Structural Iters per pass.+=\s*(\d+)$/){$data{'NEB nopt'}=$1;next}
	if(/Path specification\s+=\s([0-9a-z\-]+)\s*$/){$data{'NEB path'}=$1;next}
	if(/Climbing band after iter\s+=\s*(-?\d+)$/){$data{'NEB climb'}=$1;next}
	# - Exponent optimisation
	if(/optexp\{(.*)\}/){$data{'optexp'}=$1;next}
	if(/ABC\s+\d+\s+(.*)$/){push @ { $data{'ABC'} },$1;next}
	# - Number of atoms/types:
	if(/no. atoms=\s+(\d+)\s+no. types=\s+(\d+)/){$data{'Num. atoms'}=$1;$data{'Num. types'}=$2;next}
	if(/natom\s+:\s+(\d+)/){$data{'Num. atoms'}=$1;next}
	if(/nty\s+:\s+(\d+)/){$data{'Num. types'}=$1;next}
	# - Electronic levels:
	if(/nkpt\s+:\s+(\d+)/){$data{'Num. k-points'}=$1;next}
	if(/Processing filling of one-electron states/&&!$data{'Num. k-points'}){$data{'Num. k-points'}=$#{$data{'k-points'}}+1}
	if(/Filling chosen :\s+(\S+.*)/){$data{"Electronic levels (".++$data{"Spin"}.")"}.=join " ",split " ",$1;next}
	if(/spin, nfild,npfil,wtpoc :\s+(\d)\s+(\S+.*)/){$data{"Electronic levels ($1)"}.=join " ",split " ",$2;$data{"Spin"}=$1;next}
	if(/filling.*metallic/){$data{'Metallic'}=1}
	if(/filling.*unpaired\s*=\s*\?/){$data{'autospin'}=1}
	if(/filling.*smear=([a-z]*)?[ ,}]/){$data{'Smearing'}=$1}
	if(/kt=\s*([\d\.]*)/i){$data{'Temperature'}=$1;next}
	if(/Zero temp/i){$data{'Temperature'}=0;next}
	if(/finite temperature calculation, beta=\s*(\S*)$/ or /Finite temperature, kT is :\s*(\S+)$/){$data{'Temperature'}=eval($1);next}
	if(/k point\s+[\d\*]+\s+(\S.*)$/){push @ { $data{'k-points'} },$1;next}
	if(/of electrons :\s*(\d+)/){$data{'Num. electrons'}=$1;next}
	if(/NET MAGNETIC MOMENT\s+(-?\d.+) /){$data{'muB'}=$1;next}
	if(/fix_kpt_occ=FALSE/){$data{'Metallic'}=1;next}
	# - Evals are stored in the 'data' hash in arrays called 'evals'
	if(/proton charge=\s*(\S+)$/||/Charged Unit cell.*\s(\S+)$/){$data{'Charge state'}=eval($1);next}
	# - Atom positions
	if(/unit\{atomic\}/){$data{'units'}="Positions given in a.u.";$data{"unit definition"}="atomic";next}
	if(/unit\{ang.*\}/){$data{'units'}="Positions given in Angstrom.";$data{"unit definition"}="angstroms";next}
	if(/lattice\{(.*)\}/){
	    $c=$1;
	    $c=~s/,\s+/,/g;
	    $c=~s/\s+=/=/g;
	    my$a;for$a(split ",",$c){my @d=split"=",$a;if($d[0] eq "iorient"){$d[0]="orient"}$data{"lattice $d[0]"}=$d[1]}
	    if(!$data{"lattice params"}){$data{"lattice params"}=$data{"lattice a0"}}
	    if(!$data{"lattice orient"}){$data{"lattice orient"}=1}
	}
	# - Mulliken stuff and wavefunction coefficients
	if(/mulliken populations to be found between levels(.*)and(.*)$/){$data{'Mulliken analysis'}=eval($1)." -> ".eval($2);next}
	# - Energy Double Derivs
	if(/derivs.*\{(.*)\}/){@ { $data{"dds"} } = (split " ",$1);next}
	if(/ atoms for which derivatives are to be found :(.*)$/){$data{"N dds"}=$1;next}
	if(/ derivatives to be found for all atoms/){$data{"N dds"}=$data{'Num. atoms'};next}
	if(/REC/){$data{'REC'}.=($_."\n");next}
	# - Restart options:
	if(/restart\{(.*)\}/){
	    for (split ",",$1){
		s/\s//g;
		if(/^(.*)=(.*)$/){$data{"restart options $1"}=$2;}else{$data{"restart options $_"}=1}
	    }
	    next;
	}
	# - Basis
	if(/chden\{\s*(\d+)\s*\}/){$data{'Charge Density option'}=$1;next;}
	if(/SIZES : (NDIM\/NSP\/NFIT\/NBTOT) :(.*)$/){@a=split"/",lc($1);@b=split" ",$2;for(0..3){$data{"Basis $a[$_]"}=$b[$_];}next}
	if(($a,$b)=/(nfit,ndim.*):(.*)$/){$a=~s/\s//g;@a=split",",lc($a);@b=split" ",$b;for(0..3){$data{"Basis $a[$_]"}=$b[$_];}next}
	if(/DFLT/){$data{'Basis BCs'}++;next}
	if(/energy cutoff :(.*)/){$data{"Ecut"}=eval($1);next}
	if(/size of fft grid :(.*)/){@ { $data{"FFT grid"}}=(split" ",$1);next}
	if(/Lattice constant \(au\)\s*(\S+)/){$data{"Optimised a0"}=$1;next}
	if(/\"Lattice constant\"\s*(\S+)/){$data{"Optimised a0"}=$1;next}
	if(/Minimum energy \(au\) is(.*)$/){$data{"Optimised energy"}=$1;next}
	if(/Bulk modulus \(au\)\s*(\S+)/){$data{"Bulk modulus au"}=$1;next}
	if(/Bulk modulus \(SI\)\s*(\S+)/){$data{"Bulk modulus SI"}=$1;next}
	if(/A PROBLEM WAS DETECTED IN DIAGONALISATION/){$data{"DIIS warning"}++;next}
	# Lattice definition given during output	
	if(/^\s*unit vectors/){&GetLatticeVectors("P")}
	if(/^\s* CC unit vectors/){&GetLatticeVectors("C")}
	# NEB data
	if(/\s\d+\s+ichain/){
	    &GetNEBimage(
			 (!exists $data{"NEB iter"}?0:$data{"NEB iter"}+1),
			 (split)[0]);
	}
	if(/s and d/){$data{"NEB iter"}=(split)[9];&GetNEBenergies()}
	if(/saddle/){$data{"NEB saddle image"}[$data{"NEB iter"}]=(split)[5];&GetNEBsaddle($data{"NEB iter"})}
    }
}

######################################################################
#### Get the NEB energy profile data #################################
######################################################################
sub GetNEBenergies{
    print "!DBG! Getting NEB energies\n" if $options{$invocation}{'debug'}[0];
    # While one is reading non-blank lines not including 'iter', read data...
    while(($_=<RES>)!~/iter/&&!eof){ 
	if(/^\s*[!%]/){next} 
	else{
	    s/(\d)-(\d)/$1 -$2/;
	    push @ { $data{'NEB energies'}[$data{"NEB iter"}] },$_;
	}
    } 
    return;
}

######################################################################
#### Get the saddle point structure for a NEB pass ###################
######################################################################
sub GetNEBsaddle{
    print "!DBG! Getting NEB saddle point structure\n" if $options{$invocation}{'debug'}[0];
    # Add the single 'saddle' OTB structure...
    while(($_=<RES>)!~/\*\*\*/&&!eof){ 
	if(/^\s*[!%]/){next} 
	else{push @ { $data{'NEB saddle'}[$data{"NEB iter"}] },$_}
    } 
    return;
}

######################################################################
#### Get the full NEB image structure for a NEB pass #################
######################################################################
sub GetNEBimage{
    print "!DBG! Getting NEB chain structure\n" if $options{$invocation}{'debug'}[0];
    if($#_-1){die "Wrong \# of arguments passed to GetNEBimage\n"}
    # Add the single 'saddle' OTB structure...
    my ($iter,$image)=@_;
    print "!DBG! NEB iter = $iter, image = $image\n" if $options{$invocation}{'debug'}[0];
    @ { $ { $data{'NEB images'}[$iter] }[$image]}=();
    while(($_=<RES>)!~/s and d|time/&&!eof){ 
        chomp;
	if(/^\s*[!%]/){next} 
	elsif(/chai/){$image=(split)[0]}
	else{push @ { $ { $data{'NEB images'}[$iter] }[$image]},$_}
    } 
    return;
}

######################################################################
#### Rescale initial OTB to atomic units #############################
######################################################################
sub ScaleOTB{
    #
    #Input parameters are the otb set number (typically 1) and the
    #scaling factor (typically a0):
    #
    if($#_-1){die "Wrong \# of arguments passed to ScaleOTB\n"}
    my ($iter,$scale)=@_;
    for(0..$#{$data{'otb'}[$iter]}){
	my @d=split" ", $ { $data{'otb'}[$iter] } [$_];
	for(6..8){$d[$_]*=$scale;}
	${$data{'otb'}[$iter]}[$_]=(join" ",@d);
    }
}

