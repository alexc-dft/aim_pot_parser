	header=>"%!PS-Adobe-2.0\n%%Creator:  Homer\n%%BoundingBox: 0 0 ".(sprintf "%d %d",@{$homerdata{'paper'}})."\n%%Pages: 1\n%%CreationDate: ".localtime(time)."\n%%BeginSetup\n%%EndSetup\n%%Magnification: 1.0000\n%%EndComments\n%%BeginProlog\nsave\n%% Right justify string\n/RJ { stringwidth neg exch neg exch rmoveto } bind def\n%% Centre string\n/CS { stringwidth 2 div neg exch 2 div neg exch rmoveto } bind def\n%% Abreviations\n/F {fill} bind def\n/K {setrgbcolor} bind def\n/R {rlineto} bind def\n/L {lineto} bind def\n/M {moveto} bind def\n/N {newpath} bind def\n/S {stroke} bind def\n%%Triangles\n/UT {3 add M 5 0 R -5 7 R -5 -7 R closepath F} bind def\n/DT {3 sub M 5 0 R -5 -7 R -5 7 R closepath F} bind def\n%%Circles\n/circle {".$homerdata{sym}*.5." 0 360 arc} bind def\n%%Squares\n/square {".0.5*$homerdata{sym}." sub exch ".0.5*$homerdata{sym}." sub exch M $homerdata{sym} 0 R 0 $homerdata{sym} R -$homerdata{sym} 0 R closepath} bind def\n%%EndProlog\n%%BeginSetup\n%%EndSetup\n".$homerdata{linewidth}." setlinewidth\n",
	landscape=>"%%Landscape jiggery-pokery:\n270 rotate\n".(sprintf "%d %d",-0.5*($homerdata{'paper'}[0]+$homerdata{'paper'}[1]),0.5*($homerdata{'paper'}[0]-$homerdata{'paper'}[1]))." translate\n%%\n",
	footer=>"showpage\n%%Trailer\nrestore\n",
	);
    print HOMERPS $ps{header};
    if($homerdata{"landscape"}){print HOMERPS $ps{landscape}}
    # If desired, grey out the underlying bands:
    print HOMERPS "gsave\nnewpath\n0 0 moveto\n 0 $homerdata{'paper'}[1] rlineto\n ${$homerdata{'paper'}}[0] 0 rlineto\n 0 -$homerdata{'paper'}[1] rlineto\n closepath\ngsave\n1 1 1 setrgbcolor\n fill\ngrestore\n1 1 1 setrgbcolor\n 0 setlinewidth\n stroke\ngrestore\n";
