######################################################################
#### Draw a line from (x1,y1) to (x2,y2): ############################
######################################################################
sub SetLineWidth{printf HOMERPS "$_[0] setlinewidth\n"}
sub DrawLine{printf HOMERPS "N %10.5f %10.5f M %10.5f %10.5f L S\n",&Homer2Paper(@_)}
sub DrawDashedLine{printf HOMERPS "[5] 2 setdash\nN %10.5f %10.5f M %10.5f %10.5f L S\n[] 0 setdash\n",&Homer2Paper(@_)}
sub DrawBox{
    my @a=&Homer2Paper(@_);
    printf HOMERPS "N %10.5f %10.5f M 0 %10.5f R %10.5f 0 R 0 %10.5f R closepath 0.75 setgray F .0 setgray S\n",
    @a[0..1],$a[3]-$a[1],$a[2]-$a[0],$a[1]-$a[3];
}
sub SetFont{print HOMERPS "N $_[0] findfont $_[1] scalefont setfont\n"}
sub PlaceText{
    # Arguments: (x,y,string,justification,textsize,rotation angle)
    if($#_-5){die "Wrong number of arguments supplied to PlaceText ($#_!=5)\n";}
    my ($x,$y,$value,$justify,$textsize,$rotation)=(&Homer2Paper(@_[0..1]),@_[2..5]);
    if($options{$invocation}{'debug'}[0]){printf "!DBG! VALUE $value -> "}
    if($value=~/^\s*(-0.0+)/){$value=(sprintf "%5.$homerdata{d}f",0.0)}
    if($options{$invocation}{'debug'}[0]){printf "$value\n"}
    my $text="($value) ";
    if($justify=~/ centre$/){$y-=$textsize/4}
    if($justify=~/^right/){$text.="RJ "}
    elsif($justify=~/^centre/){$text.="CS "}
    elsif($justify=~/^left/){}
    else{die "Error: justification in PlaceText ($justify)\n"}
    printf HOMERPS "N %d %d M %5.2f rotate %s (%s) show %5.2f rotate\n",$x,$y,$rotation,$text,$value,-1*$rotation;
}
sub PlaceSymbol{ 
    # Arguments: (x,y,spin) 
    if($#_-2){die "Wrong number of arguments supplied to PlaceSymbol ($#_!=2)\n";}
    my ($x,$y,$spin) = (Homer2Paper(@_[0..1]),$_[2]);
    printf HOMERPS "N %10.5f %10.5f",$x,$y;    
    if($spin eq "up" or $spin eq "down"){
	printf HOMERPS "%s %10.5f %10.5f M %10.5f %10.5f L S\n",
	(($spin eq "up")?" UT S\nN ":" DT S\nN "),$x,$y+(($spin eq "up")?3:-3),$x,$y+(($spin eq "up")?-7:7);
    }elsif($spin eq "av"){
	print HOMERPS " $homerdata{'filled symbol'} gsave 0 setgray F grestore gsave 0 setlinewidth S grestore\n";
    }elsif($spin eq "empty"){
	print HOMERPS " $homerdata{'empty symbol'} gsave 1 setgray F grestore S\n";
    }else{
	die "Eh? spin = '$spin'\t";
    }
}

######################################################################
#### Versio 57+ lattice definitions ##################################
######################################################################

sub LatticeDefinitions{
    #Up to six parameters to define the lattice:
    my $type=$_[0];
    my $orient=$_[1]-1;
    my @scale=(split" ",$_[2]);
    
    if(!$#scale){$scale[1]=$scale[2]=$scale[0]}
    
    my @p=@_[3..$#_];
    
    my %primitive=(
	"cub-p" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[0]],
	"cub-i" => [-0.5*$p[0],0.5*$p[0],0.5*$p[0],
		    0.5*$p[0],-0.5*$p[0],0.5*$p[0],
		    0.5*$p[0],0.5*$p[0],-0.5*$p[0]],
	"cub-f" => [0.5*$p[0],0.5*$p[0],0,
		    0,0.5*$p[0],0.5*$p[0],
		    0.5*$p[0],0,0.5*$p[0]],
	"tet-p" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[1],
		    0.5*$p[0],0.5*$p[0],0,
		    -0.5*$p[0],0.5*$p[0],0,
		    0,0,$p[1]],
	"tet-i" => [-0.5*$p[0],0.5*$p[0],0.5*$p[1],
		    0.5*$p[0],-0.5*$p[0],0.5*$p[1],
		    0.5*$p[0],0.5*$p[0],-0.5*$p[1],
		    -0.5*$p[0],0,0.5*$p[1],
		    0.5*$p[0],0,0.5*$p[1],
		    0,-0.5*$p[0],-0.5*$p[1]],
	"ort-p" => [$p[0],0,0,
		    0,$p[1],0,
		    0,0,$p[2]],
	"ort-i" => [-0.5*$p[0],0.5*$p[1],0.5*$p[2],
		    0.5*$p[0],-0.5*$p[1],0.5*$p[2],
		    0.5*$p[0],0.5*$p[1],-0.5*$p[2]],
	"ort-c" => [0.5*$p[0],0.5*$p[1],0,
		    -0.5*$p[0],0.5*$p[1],0,
		    0,0,$p[2]],
	"ort-f" => [0.5*$p[0],0.5*$p[1],0,
		    0.5*$p[0],0,0.5*$p[2],
		    0,0.5*$p[1],0.5*$p[2]],
	"mon-p" => [$p[0],0,0,
		    0,$p[1],0,
		    $p[2]*sin($p[3]),0,$p[2]*cos($p[3])],
	"mon-c" => [0.5*$p[0],-0.5*$p[1],0,
		    0.5*$p[0],0.5*$p[1],0,
		    $p[2]*sin($p[3]),0,$p[2]*cos($p[3])],
	"trc-p" => [$p[0],0,0,
		    $p[1],$p[2],0,
		    $p[3],$p[4],$p[5]],
	"trg-r" => [
	    $p[0],$p[1],$p[1],
	    $p[1],$p[0],$p[1],
	    $p[1],$p[1],$p[0],
	    $p[1],0,$p[0],
	    -0.5*$p[1],0.5*sqrt(3)*$p[1],$p[0],
	    -0.5*$p[1],-0.5*sqrt(3)*$p[1],$p[0],
	    $p[0]*sin($p[1]),0,$p[0]*cos($p[1]),
	    -0.5*$p[0]*sin($p[1]),0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
	    -0.5*$p[0]*sin($p[1]),-0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
	    $p[0]*(1+$p[1]),$p[0]*$p[1],$p[0]*$p[1],
	    $p[0]*$p[1],$p[0]*(1+$p[1]),$p[0]*$p[1],
	    $p[0]*$p[1],$p[0]*$p[1],$p[0]*(1+$p[1])
	],
	"hex-p" => [
	    $p[0],0,0,
	    -0.5*$p[0],0.5*sqrt(3)*$p[0],0,
	    0,0,$p[1],
	    0.5*$p[0],-0.5*sqrt(3)*$p[0],0,
	    0.5*$p[0],0.5*sqrt(3)*$p[0],0,
	    0,0,$p[1]
	]
	);
    my %conventional=(
	"cub-p" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[0]],
	"cub-i" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[0]],
	"cub-f" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[0]],
	"tet-p" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[1],
		    $p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[1]],
	"tet-i" => [$p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[1],
		    $p[0],0,0,
		    0,$p[0],0,
		    0,0,$p[1]],
	"ort-p" => [$p[0],0,0,
		    0,$p[1],0,
		    0,0,$p[2]],
	"ort-i" => [$p[0],0,0,
		    0,$p[1],0,
		    0,0,$p[2]],
	"ort-c" => [$p[0],0,0,
		    0,$p[1],0,
		    0,0,$p[2]],
	"ort-f" => [$p[0],0,0,
		    0,$p[1],0,
		    0,0,$p[2]],
	"mon-p" => [$p[0],0,0,
		    0,$p[1],0,
		    $p[2]*sin($p[3]),0,$p[2]*cos($p[3])],
	"mon-c" => [$p[0],0,0,
		    0,$p[1],0,
		    $p[2]*sin($p[3]),0,$p[2]*cos($p[3])],
	"trc-p" => [$p[0],0,0,
		    $p[1],$p[2],0,
		    $p[3],$p[4],$p[5]],
	"trg-r" => [
	    $p[0],$p[1],$p[1],
	    $p[1],$p[0],$p[1],
	    $p[1],$p[1],$p[0],
	    $p[1],0,$p[0],
	    -0.5*$p[1],0.5*sqrt(3)*$p[1],$p[0],
	    -0.5*$p[1],-0.5*sqrt(3)*$p[1],$p[0],
	    $p[0]*sin($p[1]),0,$p[0]*cos($p[1]),
	    -0.5*$p[0]*sin($p[1]),0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
	    -0.5*$p[0]*sin($p[1]),-0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
	    $p[0]*(1+$p[1]),$p[0]*$p[1],$p[0]*$p[1],
	    $p[0]*$p[1],$p[0]*(1+$p[1]),$p[0]*$p[1],
	    $p[0]*$p[1],$p[0]*$p[1],$p[0]*(1+$p[1])
	],
	"hex-p" => [
	    $p[0],0,0,
	    -0.5*$p[0],0.5*sqrt(3)*$p[0],0,
	    0,0,$p[1],
	    0.5*$p[0],-0.5*sqrt(3)*$p[0],0,
	    0.5*$p[0],0.5*sqrt(3)*$p[0],0,
	    0,0,$p[1]
	]
	);
    
    #Pre-v57 definitions:
    @{ $primitive{"fcc"} }=(0.5*$p[0],0.5*$p[0],0,
			    0.5*$p[0],0,0.5*$p[0],
			    0,0.5*$p[0],0.5*$p[0]);
    @{ $conventional{"fcc"} }=(0.5*$p[0],0.5*$p[0],0,
			       0.5*$p[0],0,0.5*$p[0],
			       0,0.5*$p[0],0.5*$p[0]);
    @{ $primitive{"bcc"} }=@{ $primitive{"cub-i"} };
    @{ $conventional{"bcc"} }=@{ $primitive{"cub-i"} };
    @{ $primitive{"cubic"} }=@{ $primitive{"cub-p"} };
    @{ $conventional{"cubic"} }=@{ $primitive{"cub-p"} };
    @{ $primitive{"hex"} }=@{ $primitive{"hex-p"} }[0..8];
    #Turn "c/a" into "c":
    ${ $primitive{"hex"} }[8]*=$p[0];
    @{ $conventional{"hex"} }=@{ $primitive{"cub-p"} }[0..8];
    @{ $primitive{"rhomb"} }=(sqrt(3)*0.5*$p[0],-0.5*$p[0],0,
			      sqrt(3)*0.5*$p[0],0.5*$p[0],0,
    			      0,0,$p[1]*$p[0]);
    @{ $conventional{"rhomb"} }=(sqrt(3)*0.5*$p[0],-0.5*$p[0],0,
				 sqrt(3)*0.5*$p[0],0.5*$p[0],0,
				 0,0,$p[1]*$p[0]);
    
    
    my @vec=(@{$primitive{"$type"}}[(0+$orient*9)..(8+$orient*9)],@{$conventional{"$type"}}[(0+$orient*9)..(8+$orient*9)]);
    
    #Now apply the scaling:
    for $a (0..2){for $b (0..2){$vec[$b+$a*3]*=$scale[$a]}}
    
    return @vec;
    
}
