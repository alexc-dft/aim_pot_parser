    PlaceText(
	-4*$fontsize{ticklabel}/$homerdata{paper}[0]-$homerdata{d}*$fontsize{ticklabel}/$homerdata{paper}[0],
	0.5,
	$homerdata{"energy label"},"centre centre",$fontsize{ticklabel},90);
    if($homerdata{title}){
	if($homerdata{subtitle}){
	    HomerSetFont("title");    PlaceText(0.5,1.1,$homerdata{title},"centre",$fontsize{title},0);
	    HomerSetFont("subtitle");    PlaceText(0.5,1.05,$homerdata{subtitle},"centre",$fontsize{subtitle},0);
	}else{
	    HomerSetFont("title");    PlaceText(0.5,1.05,$homerdata{title},"centre",$fontsize{title},0);
	}
    }
    # Add the tickmarks:
    &HomerTickMarks();
    # Add the spectra (includeing symbols):
    &HomerSpectra();
    # Add any annotation:
    if(@{$homerdata{text}}){&HomerAnnotation(@{$homerdata{text}});}
    # Draw the frame:
    &SetLineWidth(int(1.5*$homerdata{linewidth}));
    DrawLine(0,0,0,1);
    DrawLine(0,1,1,1);
    DrawLine(1,1,1,0);
    DrawLine(1,0,0,0);
    &SetLineWidth($homerdata{linewidth});
    print HOMERPS $ps{footer};
    return $homerpsfile;
}

######################################################################
#### Add text to the plot: ###########################################
######################################################################
sub HomerAnnotation{
    print "!DBG! In HomerAnnotation\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to HomerAnnotation ($#_!>=0)" if (!($#_+1));    
    my(@text)=(@_);
    # The location of the text is given by @_[0..1] The first term is
    # already in normal units, and the second is in eV and must be
    # converted.
    for(@text){
	my (@a);
	(/^\s*(\S+)\s+(\S+)\s+"(.*)"/);@a=($1,$2,$3);
	die "Wrongly formatted annotation: $_\n" if (!($#a+2));
	PlaceText($a[0],&eV2normal($a[1]),$a[2],"centre centre",$fontsize{columnlabel},0);
    }
}

######################################################################
#### Add gray areas to represent the valence and conduction bands ####
######################################################################
sub HomerBands{
    print "!DBG! In HomerBands\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to HomerBands ($#_!=2)" if ($#_-2);    
    my($Evmin,$Ev,$Ec)=(@_);
    die "Band edges wrongly formated in input\n" if($Ev>$Ec || $Evmin>$Ev);
    
    print "!DBG! Valence band: $Evmin -- $Ev, Conduction band: $Ec +\n" if $options{$invocation}{'debug'}[0];
    
    if($Evmin eq "a"){DrawBox(0,0,1,$Ev)}
    elsif($Evmin>0&&$Ev<1){DrawBox(0,$Evmin,1,$Ev)}
    elsif($Evmin>0&&$Ev>1){DrawBox(0,$Evmin,1,1)}
    elsif($Evmin<0&&$Ev>0){DrawBox(0,0,1,$Ev)}
    if($Ec<1){DrawBox(0,1,1,$Ec)}
}

######################################################################
#### Work out the tick mark spacing: #################################
######################################################################
sub HomerSpectra{
    print "!DBG! In HomerSpectra\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to HomerSpectra ($#_)" if ($#_+1);    
    print "!DBG! set=$set\n" if $options{$invocation}{'debug'}[0];    
    # Calculate the width of each spectrum and the amount of space between them:
    if($homerdata{s}){
	$gap=(1+1/$homerdata{s})*$set-1;
	print "!DBG! 1/Gap=$gap\n" if $options{$invocation}{'debug'}[0];    
	$gap=1/$gap;
	$width=$gap/$homerdata{s}}
    else{$gap=0;$width=1/$set}
    if($set==0){die "Error - no sets detected for HomerSpectra\n"}
    if($set==1){$gap=0;$width=1}
    print "!DBG! Gap=$gap / Width=$width\n" if $options{$invocation}{'debug'}[0];    
    
    # Now plot the levels and add the labels:
    HomerSetFont("columnlabel");
    my @labels=(split"","abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ");
    my (@deg);$homerdata{"tol"}/=$homerdata{range};
    
    # Loop over the eigenvalue sets:
    for $s (1..$set){	
	
	# Do we print a dividing line?
	if($s!=$set && (exists $homerdata{"evals down $s"}||$homerdata{"evals av $s"}) && $homerdata{dividers}){
	    DrawDashedLine(($s*($width+$gap)-$gap*.5),0,($s*($width+$gap)-$gap*.5),1);
	}
	
	#Work out where to start/stop plotting symbols:
	my @empty=(split" ",$homerdata{"evals empty $s"});
	my $filled=$homerdata{"evals up $s"}+$homerdata{"evals down $s"}+$homerdata{"evals av $s"};
	
	my $estart=$homerdata{levels}[$s][$homerdata{"evals levels $s"}-$empty[0]-$filled];
	my $estop=$homerdata{levels}[$s][$homerdata{"evals levels $s"}-$empty[in0]+$empty[1]-1];
	
	if($options{$invocation}{'debug'}[0]){print "!DBG! estart \& estop: $estart $estop\n";}	
	
	# Work out what the label is:
	my $l;
	if(exists $homerdata{"evals label $s"}){
	    $l=$homerdata{"evals label $s"};
	}elsif(exists $homerdata{"evals updown $s"}){
	    $l=$homerdata{"evals updown $s"};
	}else{
	    $l="(".(shift@labels).")";
	}
	
	# Output some postscript for the label:
	if($homerdata{"labels"} eq "bottom"  && !$updown){
	    if(exists $homerdata{"evals label $s"}){
		if($homerdata{"evals rotatelabel $s"}){
		    PlaceText((($s-1)*($width+$gap)+$width*0.5)+($fontsize{columnlabel}*0.5)/$homerdata{paper}[0],
			      0.0,$l,"right centre",$fontsize{columnlabel},90);
		}else{
		    PlaceText((($s-1)*($width+$gap)+$width*0.5),-2*$fontsize{columnlabel}/$homerdata{paper}[1],$l,"centre",$fontsize{columnlabel},0);
		}
	    }elsif(exists $homerdata{"evals updown $s"}){
		$updown=2;
		if($homerdata{"evals rotatelabel $s"}){
		    PlaceText((($s-1)*($width+$gap)+$width+$gap*0.5)+($fontsize{columnlabel}*0.5)/$homerdata{paper}[0],
			      0.0,$l,"right centre",$fontsize{columnlabel},90);
		}else{
		    PlaceText((($s-1)*($width+$gap)+$width+$gap*0.5),-2*$fontsize{columnlabel}/$homerdata{paper}[1],$l,"centre",$fontsize{columnlabel},0);
		}
	    }else{	
		PlaceText((($s-1)*($width+$gap)+$width*0.5),-2*$fontsize{columnlabel}/$homerdata{paper}[1],$l,"centre",$fontsize{columnlabel},0);
	    }	    
	}
	if($updown){$updown--}
	
	#Individual band shading:
	if($homerdata{"evals bands $s"}){
	    $xmin=($s-1)*($width+$gap);
	    $xmax=$s*($width+$gap)-$gap;
	    @y=&eV2normal(split" ",$homerdata{"evals bands $s"});
	    for(0..$#y){if($y[$_]<0){$y[$_]=0}if($y[$_]>1){$y[$_]=1}}
	    #Full valence band definition?
	    if($#y==2){DrawBox($xmin,$y[0],$xmax,$y[1]);DrawBox($xmin,$y[2],$xmax,1);
	    }elsif($#y==1){DrawBox($xmin,0,$xmax,$y[0]);DrawBox($xmin,$y[1],$xmax,1);
	    }else{die "Wrong band data passed for eval band edges\n"}
	}
	
	# Now for the plotting of the levels:
	my ($current,$level);@deg=();
	for $e (@{$homerdata{levels}[$s]}){
	    # As a side-effect, calculate degeneracies:
	    if($e<=$current+$homerdata{"tol"}){
		$deg[$level].=" $e";
	    }else{
		$level++;$deg[$level]=$current=$e;
	    }
	    # If the level is in the window, draw a line:
	    next if $e<0;
	    last if $e>1;
	    DrawLine(($s-1)*($width+$gap),$e,$s*($width+$gap)-$gap,$e);
	}
	
	if($options{$invocation}{'debug'}[0]){
	    print "!DBG! tol = $homerdata{'tol'}\n";
	    for(0..$level){print "!DBG! deg[$_] = $deg[$_]\n"}
	}
	
	# Now place the symbols...
	my ($start,$stop,$nel,$b,$blast);$start=$stop=0;
	my $stag=0.05/$set;
	$nel=($homerdata{"evals levels $s"}-$empty[0])*(1+(exists $homerdata{"evals av $s"}))+$homerdata{"evals partial $s"};	
	for $e (@deg){ 
	    if($options{$invocation}{'debug'}[0]){print "!DBG! e: $e\n";}			
	    
	    if(!$start&&$estart&&$e=~/(^$estart| $estart | $estart$)/&&(split" ",$e)[0]>0){
		$start--;
		if($options{$invocation}{'debug'}[0]){print "!DBG! start: $estart $e $start\n";}	
		
	    }
	    if($start&&(split " ",$e)[0]>0){$start*=-1}
	    if($estop&&$e=~/(^$estop| $estop | $estop$)/){
		$stop++;
		if($options{$invocation}{'debug'}[0]){print "!DBG! stop(1): $estop $e $stop\n";}
	    }
	    if((split " ",$e)[0]>1){$stop++;
				    if($options{$invocation}{'debug'}[0]){print "!DBG! stop(2): $estop $e $stop\n";}
	    }
	    if(!$e){ print $e;next }
	    #Retain the last value for "staggering":
	    $blast=$b;
	    #Average over the 'degenerate' states:	    
	    $b=0;@x=(split" ",$e);for$a(@x){$b+=$a}$b/=($#x+1);
	    if($start){
		my ($spin,$a);
		if($homerdata{"stagger"}){
		    if(($b-$blast)<5e-3){
			if($nstagger==2){$nstagger=1;if($stagger<0){$stagger-=$stag}else{$stagger+=$stag}}
			elsif($nstagger==1){$nstagger=2;$stagger*=-1}
			elsif($nstagger==0){$nstagger=1;$stagger+=$stag}
		    }else{
			$nstagger=0;$stagger=0;
		    }
		}else{$stagger=0}
		$a=1;
		while($a<=($#x+1)*(1+(exists $homerdata{"evals av $s"}))){
		    if($nel-$a<0){$spin="empty"}
		    elsif(exists $homerdata{"evals up $s"}){$spin="up"}
		    elsif(exists $homerdata{"evals down $s"}){$spin="down"}
		    elsif(exists $homerdata{"evals av $s"}){$spin="av"}
		    else{die "Yikes - error in placing symbols in HomerSpectra\n"}
		    #If the average symbol is an arrow, alternate up and down:
		    if($spin eq "av" && $homerdata{"filled symbol"} eq "arrow"){
			if($AvArrow eq "up"){$AvArrow="down"}else{$AvArrow="up"}
			$spin=$AvArrow;
		    }
		    if($options{$invocation}{'debug'}[0]){print "!DBG! Before PlaceSymbol:  $a, $b, $blast, ",$b-$blast,", $stagger\n"}
		    if($b>=0 && $b<=1){
			PlaceSymbol(
			    ($s-1)*($width+$gap)
			    +$width*$a/(($#x+1)*(1+(exists $homerdata{"evals av $s"}))+1)
			    +$stagger,
			    $b,
			    $spin
			    );
		    }
		    $a++;
		}
	    }
	    $nel-=($#x+1)*(1+(exists $homerdata{"evals av $s"}));
	    last if $stop;
	}
    }
}

######################################################################
#### Work out the tick mark spacing: #################################
######################################################################
sub HomerTickMarks{
    print "!DBG! In HomerTickMarks\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to HomerTickMarks ($#_)" if ($#_+1);    
    # If the tick spacing has been dictated, use it:
    if($homerdata{ticks}){($homerdata{"major tick"},$homerdata{"minor tick"})=(split " ",$homerdata{ticks})}
    # ...else generate a sensible scheme based on the range:
    else{
	print "!DBG! range = $homerdata{range} eV\n" if $options{$invocation}{'debug'}[0];	
	$homerdata{"major tick"}=$homerdata{"minor tick"}=10**((int(log(2*$homerdata{range})/log(10)))-1);$homerdata{"minor tick"}*=0.2;
    }
    # Where is the lowest major and minor tick mark?
    if($homerdata{emin}>0){
	$homerdata{"first minor tick"}=int(($homerdata{emin}-0.00001)/$homerdata{"minor tick"}+1)*$homerdata{"minor tick"};
	$homerdata{"first major tick"}=int(($homerdata{emin}-0.00001)/$homerdata{"major tick"}+1)*$homerdata{"major tick"};
    }else{
	$homerdata{"first minor tick"}=int(($homerdata{emin}-0.00001)/$homerdata{"minor tick"})*$homerdata{"minor tick"};
	$homerdata{"first major tick"}=int(($homerdata{emin}-0.00001)/$homerdata{"major tick"})*$homerdata{"major tick"};
    }
    print "!DBG! ticks: $homerdata{'major tick'} $homerdata{'minor tick'} eV\n" if $options{$invocation}{'debug'}[0];	
    print "!DBG! first ticks: $homerdata{'first major tick'} $homerdata{'first minor tick'} eV\n" if $options{$invocation}{'debug'}[0];	
    
    # Now we must convert these numbers to the "normalised" scheme:
    $homerdata{"major tick"}/=$homerdata{range};
    $homerdata{"minor tick"}/=$homerdata{range};
    ($homerdata{"first major tick"})=(eV2normal($homerdata{"first major tick"}));
    ($homerdata{"first minor tick"})=(eV2normal($homerdata{"first minor tick"}));
    print "!DBG! ticks: $homerdata{'major tick'} $homerdata{'minor tick'} eV\n" if $options{$invocation}{'debug'}[0];	
    print "!DBG! first ticks: $homerdata{'first major tick'} $homerdata{'first minor tick'} eV\n" if $options{$invocation}{'debug'}[0];	
    
    # Now do the postscript bit:
    # Minor ticks:
    
    my $y=$homerdata{'first minor tick'};
    while($y<=1.000000001){DrawLine(0,$y,-0.01,$y);DrawLine(1,$y,1.01,$y);$y+=$homerdata{"minor tick"}}
    
    # Major ticks:
    HomerSetFont("ticklabel");
    $y=$homerdata{'first major tick'};
    while($y<=1.000000001){
	DrawLine(0,$y,-0.02,$y);
	DrawLine(1,$y,1.02,$y);
	PlaceText(-0.03,$y,(sprintf "%5.$homerdata{d}f",normal2eV($y)),"right centre",$fontsize{ticklabel},0);
	$y+=$homerdata{"major tick"}
    }
}

######################################################################
#### Work out the eV max and min after shifts and rescale: ###########
######################################################################
sub HomerNormalise{
    print "!DBG! In HomerNormalise\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to HomerNormalise ($#_)" if ($#_+1);    
    # The energy range can be forced by the input:
    if($homerdata{world}){($homerdata{emin},$homerdata{emax})=(split" ",$homerdata{world})}
    # ... else work it out...
    else{($homerdata{emin},$homerdata{emax})=(10000000,-10000000)}
    # Loop over the levels to obtain the min, max and hence the range:
    for(1..$set){
	if($homerdata{"align"}){
	    #The alignment may be from the previous set if spin polarised:
	    my $last=$_-1;
	    my $next=$_+1;
	    if(exists $homerdata{"evals up $_"}&& exists $homerdata{"evals down $next"}){
		$align=0.5*($homerdata{levels}[$_][$homerdata{"align"}-1]+$homerdata{levels}[$next][$homerdata{"align"}-1])
	    }elsif(exists $homerdata{"evals down $_"}&& exists $homerdata{"evals up $last"}){
		# Do nothing :)
	}else{$align=$homerdata{levels}[$_][$homerdata{"align"}-1]}
	    for $e (0..$#{$homerdata{levels}[$_]}){$homerdata{levels}[$_][$e]-=$align}
	}else{
	    for $e (0..$#{$homerdata{levels}[$_]}){$homerdata{levels}[$_][$e]+=($homerdata{"evals shift $_"}+$homerdata{"shift"})}
	}
	
	if(!$homerdata{world}){
	    $homerdata{emin}=(($homerdata{levels}[$_][0]<$homerdata{emin})?$homerdata{levels}[$_][0]:$homerdata{emin});
	    $homerdata{emax}=(($homerdata{levels}[$_][$#{$homerdata{levels}[$_]}]>$homerdata{emax})?$homerdata{levels}[$_][$#{$homerdata{levels}[$_]}]:$homerdata{emax});
	    printf "!DBG! %4d%10.5f%10.5f%10.5f%10.5f%10.5f\n",$_,$homerdata{levels}[$_][0],$homerdata{levels}[$_][$#{$homerdata{levels}[$_]}],$homerdata{"evals shift $_"},$homerdata{emin},$homerdata{emax} if $options{$invocation}{'debug'}[0];
	}
    }
    $homerdata{range}=$homerdata{emax}-$homerdata{emin};
    
    # The range is then increased by some fudge factor so that the top
    # and bottom levels can be seen:
    if(!$homerdata{world}){
	$homerdata{emin}=$homerdata{emin}-$homerdata{range}*$homerdata{w};
	$homerdata{emax}=$homerdata{emax}+$homerdata{range}*$homerdata{w};
	$homerdata{range}*=(1+2*$homerdata{w});
	printf "!DBG! %10.5f%10.5f%10.5f%10.5f\n",$homerdata{w},$homerdata{emin},$homerdata{emax},$homerdata{range} if $options{$invocation}{'debug'}[0];
    }    
    
    # Now loop over the levels again to produce a normalised set:
    for $s (1..$set){
	@{$homerdata{levels}[$s]}=eV2normal(@{$homerdata{levels}[$s]});
    }
}

######################################################################
#### Read in the input and build the homerdata hash: #################
######################################################################
sub HomerInput{
    print "!DBG! In HomerInput\n" if $options{$invocation}{'debug'}[0];
    die "Wrong number of arguments passed to homer" if $#_;
    my $file = $_[0];my ($levels,$evals)=(0,0);
    $set=0;
    OpenInput($file);
    # Just in case we get here from gres we need to start the line counter again...
    $.=0;
    # Now, all the input file options MUST be here so that we can check for errors...
    while(<RES>){
	chomp;
	next if /(^\s*$|^\s*%)/;
	last if /\/end\{data\}/;
	if($.==1){if(!/\/begin\{data\}/){die "Error in homer input: first line should be /begin{data}!\nFound $_\n"}else{next}}
	if(/\//){$levels=0}
	if($levels){CheckEvals($_);push @{$homerdata{levels}[$set]},(split);next} 
	if(/\/begin\{evals\}/){
	    $set++;
	    if($options{"Homer"}{"rep"}[0]){$spo=$set+1}else{$spo=0}
	    $evals=1;
	    next;
	}
	if(/\/end\{evals\}/){
	    $evals=0;
	    if($spo){
		for(sort keys %homerdata){
		    if(/^(evals.*\s)$set$/){
			my $tmp=$1;
			$tmp=~s/ up/ down/;
#			print "$_ -> $tag$spo: $homerdata{$_}\n";
			$homerdata{"$tmp$spo"}=$homerdata{$_};
		    }
		}
		@{$homerdata{levels}[$spo]}=@{$homerdata{levels}[$set]};
		$set++;
	    }
	    next;
	}
	if( $evals && /\/levels\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"evals levels $set"}=$1;$levels=1;next}
	if( $evals && /\/bands\{(.*\s+.*)\}/){for(split" ",$1){CheckANumber($_)}$homerdata{"evals bands $set"}=$1;next}
	if( $evals && /\/up\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"evals up $set"}=$1;$spo=0;next}
	if( $evals && /\/down\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"evals down $set"}=$1;$spo=0;next}
	if( $evals && /\/av\{(.*)\}/){
	    CheckAPositiveInteger($1);
	    if($spo){
		$homerdata{"evals up $set"}=$1;
	    }else{
		$homerdata{"evals av $set"}=$1;
	    }
	    next}
	if( $evals && /\/shift\{(.*)\}/){
	    CheckANumber($1);
	    $homerdata{"evals shift $set"}=$1;
	    next;
	}
	if( $evals && /\/label\{(.*)\}/){$homerdata{"evals label $set"}=$1;next}
	if( $evals && /\/updown\{(.*)\}/){$homerdata{"evals updown $set"}=$1;next}
	if( $evals && /\/partial\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"evals partial $set"}=$1;next}
	if( $evals && /\/empty\{(.*\s+.*)\}/){for(split" ",$1){CheckAPositiveInteger($_)}$homerdata{"evals empty $set"}=$1;next}
	if( $evals && /\/rotatelabel/){$homerdata{"evals rotatelabel $set"}=1;next}
	if(!$evals && /\/align\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"align"}=$1;next}
	if(!$evals && /\/shift\{(.*)\}/){CheckANumber($1);$homerdata{"shift"}=$1;next}
	if(!$evals && /\/title\{(.*)\}/){$homerdata{"title"}=$1;next}
	if(!$evals && /\/subtitle\{(.*)\}/){$homerdata{"subtitle"}=$1;next}
	if(!$evals && /\/energy label\{(.*)\}/){$homerdata{"energy label"}=$1;next}
	if(!$evals && /\/average symbol\{(square|circle)\}/){$homerdata{"filled symbol"}=$homerdata{"empty symbol"}=$1;next}
	if(!$evals && /\/average symbol\{(arrow)\}/){$homerdata{"filled symbol"}=$1;next}
	if(!$evals && /\/empty symbol\{(square|circle)\}/){$homerdata{"empty symbol"}=$1;next}
	if(!$evals && /\/stagger/){$homerdata{"stagger"}++;next}
	if(!$evals && /\/filled symbol\{(square|circle)\}/){$homerdata{"filled symbol"}=$1;next}
	if( !$evals &&/\/tickfontsize\{(.*)\}/){$fontsize{"ticklabel"}=$1;next}
	if( !$evals &&/\/labelfontsize\{(.*)\}/){$fontsize{"columnlabel"}=$1;next}
	if( !$evals &&/\/titlefontsize\{(.*)\}/){$fontsize{"title"}=$1;next}
	if( !$evals &&/\/subtitlefontsize\{(.*)\}/){$fontsize{"subtitle"}=$1;next}
	if(!$evals && /\/world\{(.*\s+.*)\}/){for(split" ",$1){CheckANumber($_)}$homerdata{"world"}=$1;next}
	if(!$evals && /\/tol\{(.*)\}/){CheckAPositiveNumber($1);$homerdata{"tol"}=$1;next}
	if(!$evals && /\/symbol size\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"sym"}=$1;next}
	if(!$evals && /\/decimals\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"d"}=$1;next}
	if(!$evals && /\/white space\{(.*)\}/){CheckAPositiveNumber($1);$homerdata{"w"}=$1*0.01;next}
	if(!$evals && /\/landscape/){$homerdata{"landscape"}=1;next}
	if(!$evals && /\/gap space\{(.*)\}/){CheckAPositiveNumber($1);$homerdata{"s"}=$1*0.01;next}
	if(!$evals && /\/ticks\{(.*\s+.*)\}/){for(split" ",$1){CheckAPositiveNumber($_)}$homerdata{"ticks"}=$1;next}
	if(!$evals && /\/paper\{(.*\s+.*)\}/){for(split" ",$1){CheckAPositiveNumber($_)}@{$homerdata{"paper"}}=(split" ",$1);next}
	if(!$evals && /\/area\{(.*\s+.*)\}/){for(split" ",$1){CheckAPositiveNumber($_)}@{$homerdata{"area"}}=(split" ",$1);next}
	if(!$evals && /\/labels\{(bottom|none)\}/){$homerdata{"labels"}=$1;next}
	if(!$evals && /\/bands\{(.*\s+.*)\}/){for(split" ",$1){CheckANumber($_)}$homerdata{"bands"}=$1;next}
	if(!$evals && /\/VBmin\{(.*)\}/){CheckANumber($1);$homerdata{"vbmin"}=$1;next}
	if(!$evals && /\/linewidth\{(.*)\}/){CheckAPositiveInteger($1);$homerdata{"linewidth"}=$1;next}
	if(!$evals && /\/dividers/){$homerdata{"dividers"}=1;next}
	if(!$evals && /\/text\{(.*\s+.*\s+".*"\s*)\}/){
	    @d=(split" ",$1);CheckAPositiveNumber($d[0]);CheckANumber($d[1]);push @{$homerdata{"text"}},$1;next
	}
	die "Error in Homer input: $_\n";
    }
    
    #
    if($options{$invocation}{debug}[0]){
	for $a (0..$set){
	    for $b (sort keys %homerdata){
		if($b=~/\s$a/){
		    print "$b: $homerdata{$b}\n";
		}
	    }	
	    print "\n";
	}
    }
    #Now make sure that the "EVALS" are sorted, and that there are the expected number of them:
    for(1..$set){
	my@b=sort bynumber @{$homerdata{levels}[$_]};
	@{$homerdata{levels}[$_]}=@b;
	my $d=$homerdata{"evals levels $_"}-$#b-1;
	if($options{$invocation}{debug}[0]){print "!DBG! $#b ",$homerdata{"evals levels $_"},"\n"}
	if($d>0){die ("Fewer levels ($d) read in than expected in set $_")}
	elsif($d<0){$d=-$d;die ("More levels ($d) read in than expected in set $_")}
    }
    
    if($options{$invocation}{debug}[0]){print "!DBG! Homerdata hash:\n";for(sort keys %homerdata){print "    $_: $homerdata{$_}\n"}}
    return($set);
}

######################################################################
#### Check that each element in the Evals lists are numbers... #######
######################################################################
sub CheckEvals{@t=split " ",$_[0];for(@t){CheckANumber($_)}}

