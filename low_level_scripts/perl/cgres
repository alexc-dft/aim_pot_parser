sub PrintBondCentreOTBFile{
    #Input is the # of the iteration to output - if '-1' is passed
    #then all OTB are output.
    die "Wrong number of arguments supplied to PrintOTBFile\n" if $#_+1;
    print "!DBG! In PrintBondCentreOTBFile\n" if $options{$invocation}{'debug'}[0];
    #Output all otb:
    if(OpenOutput(OTB,"new",$tag,"bond_centres","OTB with bond centres as atoms")){
	if(exists $data{'Num. bcs detected'}){
	    @{$data{otb}[$data{'OTBSet'}+1]}=@{$data{otb}[1]};
	    my $i=$#{$data{otb}[1]}+1;@n=(split " ",$data{Species});$n=$#n+2;
	    for(@{$data{"BC sites"}}){push @{$data{otb}[$data{OTBSet}+1]},(join " ",++$i,$n,0,0,0,0,(split)[7..9])}
	    my $scr=$data{"Num. atoms"};
	    $data{"Num. atoms"}+=$data{'Num. bcs detected'};
	    PrintOTB(OTB,$data{'OTBSet'}+1);
	    $data{"Num. atoms"}=$scr;
	}else{
	    # Work from the latest structure and the neighbour map:
	    @{$data{otb}[$data{'OTBSet'}+1]}=@{$data{otb}[$data{'OTBSet'}]};
	    my $i=$#{$data{otb}[1]}+1;@n=(split " ",$data{Species});$n=$#n+2;
	    for(@{$data{otb}[$data{'OTBSet'}]}){
		my @d=split;
		for(2..5){
		    if($d[$_]>$d[0]){
			my @d2=(split " ",$data{otb}[$data{'OTBSet'}+1][$d[$_]-1]);
			push @{$data{otb}[$data{'OTBSet'}+1]},
			(join" ",++$i,$n,0,0,0,0,($d[6]+$d2[6])*.5,($d[7]+$d2[7])*.5,($d[8]+$d2[8])*.5,"\n");
		    }
		}
	    }
	    my $scr=$data{"Num. atoms"};
	    $data{"Num. atoms"}=$#{$data{otb}[$data{'OTBSet'}+1]}+1;
	    PrintOTB(OTB,$data{'OTBSet'}+1);
	    $data{"Num. atoms"}=$scr;
	}
    }
}

######################################################################
#### Print out the OTB lines in an appropriate format: ###############
######################################################################
sub PrintOTB{
    # The input parameters are the file handle and the iteration number:
    if($#_-1){die "Wrong number of arguments sent to PrintOTB (@_)\n";}
    my ($handle,$iter)=@_;
    print $handle "\%$data{Species}\n%Set no. $iter"
	.(($iter==$data{'OTBSet'})?" (Final)":"")
	.(($iter==1)?" (Initial)\n":"\n");
    # Loop over the number of atoms in the cluster/cell
    my ($n,@d)=(0,());
    for(@{$data{'otb'}[$iter]}){
	if($iter==1){++$n;$d[$n]=$_}
	else{$d[(split)[0]]=$_;}
    }
    my $a=0;
    while(++$a<=$data{'Num. atoms'}){
	if($d[$a]){printf $handle (FormatOTB($d[$a]));}
	else{printf $handle (FormatOTB($data{'otb'}[1][$a-1]));}
    }
}

