######################################################################
#### Determine the most likely file type #############################
######################################################################
sub FileType{
    if($#_){die "Wrong number of arguments passed to File Type"}
    my $f=pop @_;
    OpenInput($f);
    my $filetype="aimpro";
    while(<RES>){
	next if /[\%\#]/;
	#If the file starts with a line containing a single integer it's probably an XYZ file:
	if(/^\s*\d+\s*$/){$filetype="xyz";last}
	#Does the line conform to OTB?
	elsif(/^\s*\d+\s+\d+\s+\d+\s+\d+\s+\d+\s+\d+\s+-?(\d+\.?\d*|\.\d+)\s+-?(\d+\.?\d*|\.\d+)\s+-?(\d+\.?\d*|\.\d+)\s*$/){$filetype="otb";last}
	else{last}
    }
    close(RES);
    return $filetype;
}

######################################################################
#### System calls are made from the system hash ######################
######################################################################
sub System{
    my $spawn="";my $len=0;
    if(@{$system{'xyz'}}&&($options{$invocation}{'xyz'}[0] ne "NONE")){
	if($options{$invocation}{'xyz'}[0]=~/jmol/){
	    if($options{$invocation}{'q'}>1){$spawn.="\tSpawning XYZ viewer\n"}
	    for(@{$system{'xyz'}}){
		system "$options{$invocation}{'xyz'}[0] $_ &";
	    }
	}else{
	    my $files = (join" ",@{$system{'xyz'}});
	    if($options{$invocation}{'q'}>1){$spawn.="\tSpawning XYZ viewer\n"}
	    system "$options{$invocation}{'xyz'}[0] $files &";
	}
    }elsif(@{$system{'xyz'}}&&$options{$invocation}{'xyz'}[0] eq "NONE"){
	print "\a\t*** No XYZ displaying software detected ***\n";
    }
    if($options{$invocation}{'xhomer'}[0]&&($options{$invocation}{'postscript'}[0] ne "NONE")){
	foreach(@{$system{'postscript'}}){
	    system "$options{$invocation}{'postscript'}[0] $_ &";
	    $nviewers++;
	}
	if($options{$invocation}{'q'}>1){
	    $spawn.=("\tSpawning ".(($nviewers>1)?"$nviewers ":"")."PS viewer".(($nviewers>1)?"s":"")."\n");
	}
    }
    
    if($spawn){
        for(split"\n",$spawn){$len=(length($_)>$len)?length($_):$len}
        for(2..$len){$stars.="*"}
        print "\n\t$stars\n$spawn\t$stars\n";
    }
}

