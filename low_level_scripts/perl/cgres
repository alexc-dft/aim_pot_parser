    elsif($options{$invocation}{'erepeat'}[0]){@repeat=split",",$options{$invocation}{'erepeat'}[0];}
    else{die "Error in PrintREPEATFile: cannot generate \@repeat!";}
    # Number of species:
    my @species=(split" ",$data{'Species'});
    my $ntypes=$#species+1;
    my (@v,$f);
    #Output repeated otb/xyz:
    my $tail=$options{$invocation}{'repeat'}[0];$tail.=($centre?".cntrd":"");
    if($options{$invocation}{'repeat'}[0]){
	my $tail=$options{$invocation}{'repeat'}[0];$tail.=($centre?".cntrd":"");
	if(!OpenOutput(RPT,"new",$tag,$tail,"Repeated unit cell (otb)")){return}
    }else{
	my $tail=$options{$invocation}{'erepeat'}[0];
	$tail.=($centre?".cntrd":"");
	$tail.=(($options{$invocation}{'xrepeatlast'}[0]||$options{$invocation}{'erepeatlast'}[0])?".last":"");
	$f=OpenOutput(XRPT,"new",$tag,$tail,"Repeated unit cell (xyz)");
	if(!$f){return}
    }
    # Print out the repeated positions: 
    if($options{$invocation}{'repeat'}[0]||$options{$invocation}{'xrepeatlast'}[0]||$options{$invocation}{'erepeatlast'}[0]){$start=$data{'OTBSet'}}else{$start=1}
    for $o ($start..$data{'OTBSet'}){
	# Suggest types for the repeated cell:
	my $ncell=0;for(@repeat){$ncell+=($_)}$ncell=($ncell+1)*$ntypes;
	if($options{$invocation}{'repeat'}[0]){
	    print RPT "%";
	    for(1..$ncell){print RPT "$data{'Species'} ";}
	    print RPT "\n";
	}else{
	    print XRPT ($data{'Num. atoms'}*
			((1+$options{$invocation}{'centre'}[0])*$repeat[0]+1)*
			((1+$options{$invocation}{'centre'}[0])*$repeat[1]+1)*
			((1+$options{$invocation}{'centre'}[0])*$repeat[2]+1))."\nRepeated : @repeat\n";
	}
	# Loop over the atoms in this set:
	for (@ { $data{'otb'}[$o] }){	  
	    my @d=(split);
	    my @LV=@{$data{"d-latt P"}};
	    if(exists $data{"d-latt P $o"}){
		@LV=@{$data{"d-latt P $o"}};
	    }
	    for ($x=-1*$repeat[0]*$centre;$x<=$repeat[0];$x++){  
		for ($y=-1*$repeat[1]*$centre;$y<=$repeat[1];$y++){  
		    for ($z=-1*$repeat[2]*$centre;$z<=$repeat[2];$z++){		
			# OTB output:
			if($options{$invocation}{'repeat'}[0]){
			    #Quick hack null neighbours array used here, -anal option can calculate for neighbours map
			    #TODO add neighbours map calculation to this routine
			    @null_neigh=(0,0,0,0);
			    if(
				$data{"unit definition"} eq "int-p"
				||
				($data{"unit definition"} eq "internal"
				 &&!$data{"restart options override-positions"})
				){
				@pos=(
				    ($d[6]+$x)/($repeat[0]*(1+$centre)+1),
				    ($d[7]+$y)/($repeat[1]*(1+$centre)+1),
				    ($d[8]+$z)/($repeat[2]*(1+$centre)+1)
				    );
			    }elsif($data{"unit definition"} eq "int-c"){
				@v=(LatticeDefinitions(
					$data{"lattice type"},
					$data{"lattice orient"},
					$data{"lattice scale"},
					1,1,1,1,1,1))[0..8];
				@pos=(
				    $d[6]+($x*$v[0]+$y*$v[3]+$z*$v[6]),
				    $d[7]+($x*$v[1]+$y*$v[4]+$z*$v[7]),
				    $d[8]+($x*$v[2]+$y*$v[5]+$z*$v[8]));
			    }elsif($data{"unit definition"} eq "atomic"
				   ||
				   #Old output where all but internal coords are rescaled to atomic during output:
				   ($data{"rescaled positions"}&&$o!=1&&($data{"unit definition"} ne "internal"))){
				
				@v=@LV;
				@pos=(
				    $d[6]+$x*$v[0]+$y*$v[3]+$z*$v[6],
				    $d[7]+$x*$v[1]+$y*$v[4]+$z*$v[7],
				    $d[8]+$x*$v[2]+$y*$v[5]+$z*$v[8]);
			    }elsif($data{"unit definition"} =~ /^ang/){
				my$a1=$const{"autoang"};
				#Only rescale the first values (eg a data file):
				if($o>1){$a1=1}
				@v=@LV;
				@pos=(
				    $d[6]+($x*$v[0]+$y*$v[3]+$z*$v[6])*$a1,
				    $d[7]+($x*$v[1]+$y*$v[4]+$z*$v[7])*$a1,
