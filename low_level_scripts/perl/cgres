    print "!DBG! In PrintLETESTNEB\n" if $options{$invocation}{'debug'}[0];
    #Output the final chain to a latest.neb formatted file...
    my $f=OpenOutput(NEB,"new",$tag,"","Pass $iter");
    if(!$f){return}
    printf NEB "%4d\n",$data{"NEB nimages"};
    for my $i (1..$data{"NEB nimages"}){
	#printf NEB ">> %d\n",$#{$data{"NEB images"}[$iter][$i]};
	for my $j (0..$#{$data{"NEB images"}[$iter][$i]}){
	    my@d=(split" ",$data{'NEB images'}[$iter][$i][$j]);
