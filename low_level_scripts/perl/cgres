######################################################################
#### Get the lattice definition from the data input ##################
######################################################################
sub GetLattice{
    print "!DBG! Getting lattice data\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list
    while(($_=<RES>)!~/end/&&!eof){
	if(/^\s*[!%]/){next}
	$data{'lattice reconstruction'}.=$_;
	if(/type\{(.*)\}/){$data{"lattice type"}=$1;}
	if(/a0\{(.*)\}/){
	    $data{"lattice a0"}=$1;
	    if(!$data{"lattice params"}){
		$data{"lattice params"}=$data{"lattice a0"}
	    }
	}
	if(/sum\{(.*)\}/){$data{"lattice sum"}=$1;}
	if(/vec\{(.*)\}/){$data{"lattice vecs"}.=" $1";}
    }
    return;
}

######################################################################
#### Get the lattice definition from the data input ##################
######################################################################
sub GetLatticeVectors{
    print "!DBG! Getting lattice vector from output data\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list
    my $type = $_[0]; # P(rimitive) or C(onventional)
    #Sometimes (where the lattice is being detected) the data appears twice:
    if(exists $data{"d-latt $type"}){
	delete $data{"d-latt $type"};
	delete $data{"r-latt $type"};
    }
    while(($_=<RES>)!~/end/&&!eof){
	if(/^\s*[!%]/){next}
	chomp;
	my @a=(split);
	push @ { $data{"d-latt $type"} },@a[0..2];
	push @ { $data{"r-latt $type"} },@a[3..5];
	if( $#{  $data{"r-latt $type"} } == 8){last}
    }
    return;
}

