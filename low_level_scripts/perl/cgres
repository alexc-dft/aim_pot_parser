sub Get2DD{
    print "!DBG! Getting 2DDs\n" if $options{$invocation}{'debug'}[0];
    #While one is reading lines starting with a number, add them to
    #the current list
    my %t;
    if(($_=<RES>)=~/NUMBER OF ATOMS/&&!eof){}else{my @t=(split);$t{$t[1]}++}
    while(($_=<RES>)=~/^\s*\d/&&!eof){
	my @t=(split);
	$t{$t[1]}++;
    }
    $data{'2DD'}=(join" ",(sort bynumber keys %t));
    return;
}

