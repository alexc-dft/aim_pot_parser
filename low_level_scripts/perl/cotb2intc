######################################################################
# Routines to check that strings are numbers:
######################################################################
sub CheckANumber{$n=$_[0];if($n=~/^-?(\d+\.?\d*|\.\d+)$/){return 1}else{return 0}}
sub CheckAPositiveNumber{$n=$_[0];if($n=~/^(\d+\.?\d*|\.\d+)$/){return 1}else{return 0}}
sub CheckAnInteger{$n=$_[0];if($n=~/^-?\d+$/){return 1}else{return 0}}
sub CheckAPositiveInteger{$n=$_[0];if($n=~/^\d+$/){return 1}else{return 0}}
