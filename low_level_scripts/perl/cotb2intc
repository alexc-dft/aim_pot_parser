######################################################################
#Get the data files information:
######################################################################
sub ScanDataFiles{
    open IN, "<$files[0]" or die;
    $getpos=$part=$start_otb_line=0;
    @species=();
    while(<IN>){
    if($getpos==1&&$.==$start_otb_line&&/^\s*%(.*)$/){@species=(split" ",$1)}
	next if /^\s*[!%]|^\s*$/;
	if($getpos==1){
	    if(/end\{pos/){
		$part++;
		$getpos=0;
	    }else{
		$pos.=$_;
		next;
	    }
	}
	elsif(/lattice(\{.*\})/){$lattice=$1}
	elsif(/begin\[atomic\]\{positions\}/){
	    s/atomic/int-c/;
	    $getpos=1;
	    $start_otb_line=$.+1;
	}
#	$stuff[$part].=$_;
    }
}
