######################################################################
# Just recentre the atoms as requierd, and ensure the atoms so that
# they are all within the parallelapiped defined by the lattice
# vectors
######################################################################
sub Recentre{
    @centre=&ScaleVec(&AddVec(@vec[0..2],&AddVec(@vec[3..8])),0.5);
    @pcentre=&ReturnCoefs(@vec,@centre);
    
    for$x(split"\n",$pos){
	my@otb=(split" ",$x);	
	for$i(0..2){
	    $otb[$i+6]-=($o[$i]-$centre[$i]);
	}
	
	#Inside?
	
	@c=&ReturnCoefs(@vec,@otb[6..8]);
	
	if($compact){		
	    for(0..2){
		while($c[$_]<0){$c[$_]+=1}
		while($c[$_]>=1){$c[$_]-=1}
	    }
	}

	@otb[6..8]=@c;
	
	if($recentre){
	    for(0..2){$otb[$_+6]-=$pcentre[$_]}
	}
	
	$pos2.=(sprintf"%4d %2d %5d %5d %5d %5d %17.10f %17.10f %17.10f\n",
		@otb);
	
    }
}

