######################################################################
# Build a new data file from the best bits of the original files:
######################################################################
sub BuildNewDataFile{
    open OUT, ">otb.intc" or die;
    if(@species){print OUT "%".(join" ",@species)."\n";}
    print OUT "$pos2";
    print STDERR "Written int-c positional otb to otb.intc\n";
}
