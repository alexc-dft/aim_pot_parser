######################################################################
# Returns point in terms of the coefs of basis vectors
######################################################################
sub ReturnCoefs{
    if($#_-11){die "Wrong number of terms ($#_!=11) passed to ReturnCoefs\n"}
    
    my@v=@_[0..8]; # These are the basis vectors
    my@p=@_[9..11]; # This is the 'point'
    my@a=();
    my@rhs=();
    
    #First generate the vi.vj matrix:
    $a[0]=&dp(@v[0..2],@v[0..2]);
    $a[1]=&dp(@v[0..2],@v[3..5]);
    $a[2]=&dp(@v[0..2],@v[6..8]);
    $a[3]=&dp(@v[3..5],@v[0..2]);
    $a[4]=&dp(@v[3..5],@v[3..5]);
    $a[5]=&dp(@v[3..5],@v[6..8]);
    $a[6]=&dp(@v[6..8],@v[0..2]);
    $a[7]=&dp(@v[6..8],@v[3..5]);
    $a[8]=&dp(@v[6..8],@v[6..8]);

    #Then generate the vi.p:
    $rhs[0]=&dp(@v[0..2],@p);
    $rhs[1]=&dp(@v[3..5],@p);
    $rhs[2]=&dp(@v[6..8],@p);
    
    my @c=&MatVecMult(&Inv(@a),@rhs);

    my @e=&Inv(@a);

    my @d=&MatMult(@e,@a);
   
    return @c;
}
