######################################################################
# Analyse the command line options:
######################################################################
sub CommandLine{
    my@a=@ARGV;
    while(@a){
	my$a=shift@a;
	#Look for data files:
	if(-e $a){push @files,$a}
	elsif($a eq "-h"){&Help}
	elsif($a eq "-c"){$compact=1}
	elsif($a eq "-r"){$recentre=1}
	elsif($a eq "-o"){
	    if($#a>1){
		for(0..2){$o[$_]=shift@a}
	    }else{die "Not 3 values for -os\n"}}
	else{
	    die "Unknown Command Line option: '$a'\n"}
    }
    
    #Some checks
    if($#files){
	printf"Wrong number of files supplied: I need 1 file, you supplied %d!\n",$#files+1;
	&Help;
    }
    for$a(@o){
	unless(&CheckANumber($a)){
	    die "Value provided for '-o' ($a) not recognised as a number\n";
	}
    }	
}
