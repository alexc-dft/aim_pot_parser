######################################################################
# Convert lattice information into basis vectors:
######################################################################
sub GetLatticeInfo{
    $type=$params=0;
    $scale=$orient=1;
    if($lattice=~/type\s*=\s*([a-z]{3}-[a-z])/){$type=$1;}
    if($lattice=~/orient\s*=\s*(\d)/){$orient=$1;}
    if($lattice=~/scale\s*=\s*([\d\s]+)[,\}]/){$scale=$1;}
    if($lattice=~/params\s*=\s*([-?\d\s\.]+)[,\}]/){$params=$1;}
    
    #Check that the minimum info exists:
    if(!$params&&!$type){
	die"Can't get lattice info from '$lattice'\n";
    }

    @vec=&GetLatticeDefinitions($type,$orient,(split" ",$params));

    @scale=split" ",$scale;
    #Scale not factored into int-c conversion

}
