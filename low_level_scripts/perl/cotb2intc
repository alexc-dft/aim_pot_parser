sub MatVecMult{
    if($#_-11){die"Wrong number of arguments passed to MatVecMult\n"}
    my@a=@_[0..8];my@b=@_[9..11];my@c=();
    $c[0]=$a[0]*$b[0]+$a[1]*$b[1]+$a[2]*$b[2];
    $c[1]=$a[3]*$b[0]+$a[4]*$b[1]+$a[5]*$b[2];
    $c[2]=$a[6]*$b[0]+$a[7]*$b[1]+$a[8]*$b[2];
    return@c;
}

sub MatMult{
    if($#_-17){die"Wrong number of arguments passed to MatMult\n"}
    my@a=@_[0..8];my@b=@_[9..17];my@c=();
    $c[0]=$a[0]*$b[0]+$a[1]*$b[3]+$a[2]*$b[6];
    $c[1]=$a[0]*$b[1]+$a[1]*$b[4]+$a[2]*$b[7];
    $c[2]=$a[0]*$b[2]+$a[1]*$b[5]+$a[2]*$b[8];
    $c[3]=$a[3]*$b[0]+$a[4]*$b[3]+$a[5]*$b[6];
    $c[4]=$a[3]*$b[1]+$a[4]*$b[4]+$a[5]*$b[7];
    $c[5]=$a[3]*$b[2]+$a[4]*$b[5]+$a[5]*$b[8];
    $c[6]=$a[6]*$b[0]+$a[7]*$b[3]+$a[8]*$b[6];
    $c[7]=$a[6]*$b[1]+$a[7]*$b[4]+$a[8]*$b[7];
    $c[8]=$a[6]*$b[2]+$a[7]*$b[5]+$a[8]*$b[8];
    return@c;
}

sub PrintScalar{
    if($#_-1){die"Wrong number of arguments passed to PrintScalar\n"}
    printf STDERR "%20s:",$_[0];my@a=@_[1..1];for$j(0..0){printf " %10.5f",shift@a}print"\n";
}

sub PrintVec{
    if($#_-3){die"Wrong number of arguments passed to PrintVec\n"}
    printf STDERR "%20s:",$_[0];my@a=@_[1..3];for$j(0..2){printf " %10.5f",shift@a}print"\n";
}

sub PrintMat{
    if($#_-9){die"Wrong number of arguments passed to PrintMat\n"}
    printf STDERR "%s\n",$_[0];my@a=@_[1..9];for$i(0..2){for$j(0..2){printf " %10.5f",shift@a}print"\n"}
}

# Inverse:
sub Inv{
    if($#_-8){die"Wrong number of arguments passed to Inv\n"}

#| a11 a12 a13 |-1             |   a33a22-a32a23  -(a33a12-a32a13)   a23a12-a22a13  |
#| a21 a22 a23 |    =  1/DET * | -(a33a21-a31a23)   a33a11-a31a13  -(a23a11-a21a13) |
#| a31 a32 a33 |               |   a32a21-a31a22  -(a32a11-a31a12)   a22a11-a21a12  |

    my@a=@_;
    my$det=&Det(@a);

    if(!$det){die "Singular matrix obtained! @a\nAre you sure lattice params are correctly defined (i.e. params=)?\n\n"}
    
    my@b;
    $b[0]=$a[8]*$a[4]-$a[7]*$a[5];
    $b[1]=$a[7]*$a[2]-$a[8]*$a[1];
    $b[2]=$a[5]*$a[1]-$a[4]*$a[2];
    $b[3]=$a[6]*$a[5]-$a[3]*$a[8];
    $b[4]=$a[8]*$a[0]-$a[2]*$a[6];
    $b[5]=$a[2]*$a[3]-$a[0]*$a[5];
    $b[6]=$a[3]*$a[7]-$a[4]*$a[6];
    $b[7]=$a[1]*$a[6]-$a[0]*$a[7];
    $b[8]=$a[0]*$a[4]-$a[1]*$a[3];
    return(&Scale(@b,1/$det));
}

# Scale a 3 vector:
sub ScaleVec{
    if($#_-3){die"Wrong number of arguments ($#_) passed to ScaleVec\n"}
    my@a=@_[0..2];for(0..2){$a[$_]*=$_[3]}return@a;
}

# Scale a 3x3 matrix:
sub Scale{
    if($#_-9){die"Wrong number of arguments passed to Scale\n"}
    my@a=@_[0..8];for(0..8){$a[$_]*=$_[9]}return@a;
}

# Determinant:
sub Det{
    if($#_-8){die"Wrong number of arguments passed to Det\n"}
    my@a=@_;
    my$det=abs(
	       $a[0]*($a[8]*$a[4]-$a[7]*$a[5])
	       -$a[3]*($a[8]*$a[1]-$a[7]*$a[2])
	       +$a[6]*($a[5]*$a[1]-$a[4]*$a[2])
	       );
    return$det;
}

# Add two 3-vectors:
sub AddVec{
    if($#_-5){die"Wrong number ($#_) of arguments passed to AddVec\n"}
    my@a=();for(0..2){$a[$_]=($_[$_]+$_[$_+3])}return@a;
}

# Dot Product of two three-vectors.
sub dp{
    if($#_-5){die"Wrong number of arguments passed to dp\n"}
    my$dp=0;for(0..2){$dp+=($_[$_]*$_[$_+3])}return$dp;
}

#Cross product of two three vectors:
sub cp{
    if($#_-5){die"Wrong number of arguments passed to cp\n"}
    my@a=();
    $a[0]=$_[1]*$_[5]-$_[2]*$_[4];
    $a[1]=$_[2]*$_[3]-$_[0]*$_[5];
    $a[2]=$_[0]*$_[4]-$_[1]*$_[3];
    return@a;
}

#Calculate lattice vectors based upon definition:
sub GetLatticeDefinitions{
    my $type=$_[0];
    my $orient=$_[1];
    my @p=@_[2..$#_];
    @p=(@p,0,0,0,0,0);
    %conventional=(
        "cub-p" => [$p[0],0,0,
                0,$p[0],0,
                0,0,$p[0]],
        "cub-i" => [$p[0],0,0,
                0,$p[0],0,
                0,0,$p[0]],
        "cub-f" => [$p[0],0,0,
                0,$p[0],0,
                0,0,$p[0]],
        "tet-p" => [$p[0],0,0,
                0,$p[0],0,
                0,0,$p[1],
                $p[0],0,0,
                0,$p[0],0,
                0,0,$p[1]],
        "tet-i" => [$p[0],0,0,
                0,$p[0],0,
                0,0,$p[1],
                $p[0],0,0,
                0,$p[0],0,
                0,0,$p[1]],
        "ort-p" => [$p[0],0,0,
                0,$p[1],0,
                0,0,$p[2]],
        "ort-i" => [$p[0],0,0,
                0,$p[1],0,
                0,0,$p[2]],
        "ort-c" => [$p[0],0,0,
                0,$p[1],0,
                0,0,$p[2]],
        "ort-f" => [$p[0],0,0,
                0,$p[1],0,
                0,0,$p[2]],
        "mon-p" => [$p[0],0,0,
                0,$p[1],0,
                $p[2]*sin($p[3]),0,$p[2]*cos($p[3])],
        "mon-c" => [$p[0],0,0,
                0,$p[1],0,
                $p[2]*sin($p[3]),0,$p[2]*cos($p[3])],
        "trc-p" => [$p[0],0,0,
                $p[1],$p[2],0,
                $p[3],$p[4],$p[5]],
        "trg-r" => [
            $p[0],$p[1],$p[1],
            $p[1],$p[0],$p[1],
            $p[1],$p[1],$p[0],
            $p[1],0,$p[0],
            -0.5*$p[1],0.5*sqrt(3)*$p[1],$p[0],
            -0.5*$p[1],-0.5*sqrt(3)*$p[1],$p[0],
            $p[0]*sin($p[1]),0,$p[0]*cos($p[1]),
            -0.5*$p[0]*sin($p[1]),0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
            -0.5*$p[0]*sin($p[1]),-0.5*sqrt(3)*$p[0]*sin($p[1]),$p[0]*cos($p[1]),
            $p[0]*(1+$p[1]),$p[0]*$p[1],$p[0]*$p[1],
            $p[0]*$p[1],$p[0]*(1+$p[1]),$p[0]*$p[1],
            $p[0]*$p[1],$p[0]*$p[1],$p[0]*(1+$p[1])
        ],
        "hex-p" => [
            $p[0],0,0,
            -0.5*$p[0],0.5*sqrt(3)*$p[0],0,
            0,0,$p[1],
            0.5*$p[0],-0.5*sqrt(3)*$p[0],0,
            0.5*$p[0],0.5*sqrt(3)*$p[0],0,
            0,0,$p[1]
            ]
        );

    if(!exists $conventional{$type}){die "No such thing: $type\n"}
    return @{$conventional{$type}}[3*($orient-1)..(3*($orient-1)+8)];
}

######################################################################
#Return -1 for negative, +1 for positive and zero for zero.
######################################################################
sub sign{if($_[0]<0){return-1}elsif($_[0]>0){return 1}else{return 0}}
